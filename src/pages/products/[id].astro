	<script is:inline define:vars={{
		productId: product?.id,
		kodeitem: product?.item_code || product?.code,
		webStock: product?.total_inventory ?? product?.total_stock ?? 0,
		PUBLIC_API_URL
	}}>
		// Auto-Sync Background Task
		if (productId && kodeitem) {
			const checkAndSyncStock = async () => {
				try {
					const erpUrl = `https://noir.grace.gracianna.web.id/api/v1/beli1?per_page=20&q=${encodeURIComponent(kodeitem)}`;
					const res = await fetch(erpUrl);
					const json = await res.json();
					
					if (json.success && json.data && json.data.length > 0) {
						const item = json.data.find(i => i.kode === kodeitem || i.kodeitem === kodeitem);
						if (item) {
							let erpStock = 0;
							// 1. Map ERP stock to sizes
							const sizeMap = {};
							if (item.details && Array.isArray(item.details)) {
								item.details.forEach(detail => {
									let sz = (detail.size || '').trim().toUpperCase();
									if (sz === '00') sz = 'ALL SIZE';
									if (/^\d+L$/.test(sz)) sz = sz.replace('L', 'XL');
									const isSF = /\bSF\b/i.test(detail.nama || '') || (detail.nama || '').trim().toUpperCase().endsWith('SF');
									if (isSF) {
										sz = sz + ' SF';
									}
									const stock = parseInt(detail.stok || 0);
									if (!sizeMap[sz]) {
										sizeMap[sz] = stock;
									} else {
										sizeMap[sz] += stock;
									}
								});
							}

							// 2. Update existing variants stock and detect actual changes
							let needsUpdate = false;
							const existingVariants = product.variants || product.product_variants || [];
							const updatedVariants = existingVariants.map(v => {
								let varName = (v.size_name || '').toUpperCase();
								let baseSz = varName;
								if (varName.includes(' - ')) {
									baseSz = varName.split(' - ')[0].trim();
								}
								
								let newStock = sizeMap[baseSz] || 0;
								let currentStock = parseInt(v.stock || 0);
								
								if (newStock !== currentStock) {
									needsUpdate = true;
								}
								
								return {
									size_name: v.size_name,
									sku: v.sku,
									price: parseFloat(v.price || product.price || 0),
									stock: newStock,
									dalaman: v.dalaman || null
								};
							});
							
							if (needsUpdate) {
								console.log(`[Auto-Sync] Varian terdeteksi berubah, melakukan sinkronisasi...`);
								
								// Tampilkan indikator loading kecil
								const stockBadge = document.querySelector('.status-badge');
								if(stockBadge) {
									stockBadge.innerText = 'SINKRONISASI...';
									stockBadge.style.background = '#f59e0b';
									stockBadge.style.color = '#fff';
								}

								// 3. Build Full Valid Payload for Laravel
								const updatePayload = {
									name: product.name,
									price: product.price,
									type_id: product.type_id || (product.type ? product.type.id : null),
									category_ids: (product.categories || product.product_categories || []).map(c => c.id || c.category_id),
									motif_ids: (product.motifs || product.product_motifs || []).map(m => m.id || m.motif_id),
									colors: product.colors || [],
									description: product.description || '',
									code: product.code || '',
									original_price: product.original_price || 0,
									item_code: product.item_code || '',
									image_url: product.image_url || '',
									images: product.images || [],
									tokopedia_url: product.tokopedia_url || '',
									variants: updatedVariants,
									is_active: product.is_active !== undefined ? product.is_active : true
								};

								// Panggil backend
								const updateRes = await fetch(`${PUBLIC_API_URL}/products/${productId}`, {
									method: 'PUT',
									headers: {
										'Content-Type': 'application/json',
										'Accept': 'application/json'
									},
									body: JSON.stringify(updatePayload) 
								});
								
								if (updateRes.ok) {
									console.log("[Auto-Sync] Berhasil, memuat ulang halaman...");
									window.location.reload();
								} else {
									console.warn("[Auto-Sync] Gagal melakukan sinkronisasi dengan backend, status:", updateRes.status);
									if(stockBadge) {
										stockBadge.innerText = 'Sisa ' + webStock;
										stockBadge.style.background = '#fffbeb';
										stockBadge.style.color = '#f59e0b';
									}
								}
							} else {
								console.log("[Auto-Sync] Stok web sudah sesuai dengan ERP.");
							}
						}
					}
				} catch (e) {
					console.error("[Auto-Sync] Gagal mengecek ERP", e);
				}
			};

			// Jalankan sedikit delay agar tidak memblokir render utama UI
			setTimeout(checkAndSyncStock, 800);
		}
	</script>

	<script is:inline define:vars={{ productData: product, waNumberData: waNumber }}>
		window.product = productData;
		window.waNumber = waNumberData;
	</script>
	<script is:inline>
		// Gallery Switcher Logic
		const mainImg = document.getElementById('main-product-img');
		const thumbs = document.querySelectorAll('.thumb-item');

		if (thumbs) {
			thumbs.forEach(thumb => {
				thumb.addEventListener('click', () => {
					const newSrc = thumb.getAttribute('data-src');
					if (mainImg && newSrc) {
						mainImg.src = newSrc;
						thumbs.forEach(t => t.classList.remove('active'));
						thumb.classList.add('active');
					}
				});
			});
		}		// Variant Selection Logic
		const baseSzBtns = document.querySelectorAll('.base-sz-btn');
		const subVarBtns = document.querySelectorAll('.sub-var-btn');
		const priceDisplay = document.querySelector('.product-price');
		const badgeDisplay = document.getElementById('stock-badge');
		const waBtn = document.getElementById('wa-btn');

		if (baseSzBtns.length > 0 && subVarBtns.length > 0 && priceDisplay) {
			const updateAvailability = (stock) => {
				const isAvailable = stock > 0;
				if (badgeDisplay) {
					badgeDisplay.className = `status-badge ${stock === 0 ? 'out-of-stock' : stock <= 5 ? 'warning-stock' : ''}`;
					if (stock === 0) {
						badgeDisplay.innerHTML = '🔴 HABIS';
					} else if (stock <= 5) {
						badgeDisplay.innerHTML = '⚠️ Sisa ' + stock + ' pcs';
					} else {
						badgeDisplay.innerHTML = '🟢 Ready Stock';
					}
				}
				if (waBtn && waBtn.getAttribute('target') !== '_self') {
					waBtn.classList.toggle('btn-disabled', !isAvailable);
					const btnText = waBtn.querySelector('.btn-text');
					if (btnText) btnText.innerText = isAvailable ? 'Chat Admin' : 'Stok Ukuran Habis';
				}
			};

			const updateDalaman = (dalaman) => {
				const dynamicDalamanInfo = document.getElementById('dynamic-dalaman-info');
				if (dynamicDalamanInfo) {
					if (dalaman === 'F') {
						dynamicDalamanInfo.innerHTML = '<span style="color: #8b5a2b; background: #fff8f0; border: 1px solid #e1d3c1; padding: 4px 10px; border-radius: 6px; font-size: 0.8rem; font-weight: 700; display: inline-flex; align-items: center; gap: 4px;">✨ Furing (F)</span>';
					} else {
						dynamicDalamanInfo.innerHTML = '';
					}
				}
			};

			const updateWAMessage = (selectedVar, dalaman) => {
				if (waBtn) {
					const code = `${product.code || ''}`;
					const name = `${product.name || ''}`;
					let varText = selectedVar;
					if (dalaman === 'F') {
						varText += ' - Dengan Furing';
					} else if (dalaman === 'TF') {
						varText += ' - Tanpa Furing';
					} else if (dalaman === 'null' || !dalaman) {
						varText += ' - Tanpa Dalaman';
					} else {
						varText += ` - ${dalaman}`;
					}
					const msg = encodeURIComponent(`Halo, saya tertarik dengan produk ${name} (${code}) variasi ${varText}. Apakah masih tersedia?`);
					waBtn.setAttribute('href', `https://wa.me/${waNumber}?text=${msg}`);
				}
			};

			const selectBaseSize = (size) => {
				let visibleCount = 0;
				// Hide all sub-variants first
				subVarBtns.forEach(btn => {
					if (btn.getAttribute('data-base-size') === size) {
						btn.style.display = 'flex';
						visibleCount++;
					} else {
						btn.style.display = 'none';
					}
					btn.classList.remove('active');
				});

				// Dynamic Hide Step 2 if only 1 sub-variant exists
				const subVarContainer = document.getElementById('sub-variant-options')?.parentElement;
				if (subVarContainer) {
					if (visibleCount <= 1) {
						subVarContainer.style.display = 'none';
					} else {
						subVarContainer.style.display = 'block';
					}
				}

				// Auto-select the first visible sub-variant
				const firstVisible = Array.from(subVarBtns).find(btn => btn.getAttribute('data-base-size') === size);
				if (firstVisible) {
					firstVisible.classList.add('active');
					const price = parseInt(firstVisible.getAttribute('data-price') || '0', 10);
					if (price > 0) priceDisplay.innerText = "Rp " + price.toLocaleString('id-ID');
					const stock = parseInt(firstVisible.getAttribute('data-stock') || '0', 10);
					const dalaman = firstVisible.getAttribute('data-dalaman') || "";
					updateAvailability(stock);
					updateDalaman(dalaman);
					updateWAMessage(firstVisible.getAttribute('data-fullname'), dalaman);
				}
			};

			baseSzBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					baseSzBtns.forEach(b => b.classList.remove('active'));
					btn.classList.add('active');
					selectBaseSize(btn.getAttribute('data-size'));
				});
			});

			subVarBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					subVarBtns.forEach(b => {
						if (b.getAttribute('data-base-size') === btn.getAttribute('data-base-size')) {
							b.classList.remove('active');
						}
					});
					btn.classList.add('active');
					
					const price = parseInt(btn.getAttribute('data-price') || '0', 10);
					if (price > 0) priceDisplay.innerText = "Rp " + price.toLocaleString('id-ID');
					const stock = parseInt(btn.getAttribute('data-stock') || '0', 10);
					const dalaman = btn.getAttribute('data-dalaman') || "";
					updateAvailability(stock);
					updateDalaman(dalaman);
					updateWAMessage(btn.getAttribute('data-fullname'), dalaman);
				});
			});

			// Initial state
			const initialSize = baseSzBtns[0].getAttribute('data-size');
			selectBaseSize(initialSize);
		}

		// Start the engines
	</script>
