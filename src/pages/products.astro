export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";

const { searchParams } = Astro.url;
const typeFilter = searchParams.get("type");
const motifFilter = searchParams.get("motif");
const sizeFilter = searchParams.get("size"); // New size filter
const searchQuery = searchParams.get("q");
const minPrice = searchParams.get("minP")
	? Number(searchParams.get("minP"))
	: null;
const maxPrice = searchParams.get("maxP")
	? Number(searchParams.get("maxP"))
	: null;
const sort = searchParams.get("sort") || "newest";

const getSortUrl = (newSort: string) => {
	const p = new URLSearchParams(searchParams);
	p.set("sort", newSort);
	return `?${p.toString()}`;
};

console.log("DEBUG: products.astro", {
	typeFilter,
	motifFilter,
	sizeFilter,
	searchQuery,
	minPrice,
	maxPrice,
	sort,
});

// Fetch Types and Motifs for the filter UI
let typesData: any[] = [];
let motifsData: any[] = [];
let sizesData: any[] = [];
let productsData: any[] = [];
let hierarchicalTypes: any[] = [];
let activePathIds: any[] = [];
let targetType: any = null;
let settings: any = { contact_whatsapp: "628123456789" };

if (supabase) {
	const { data: t } = await supabase.from("types").select("*");
	const { data: m } = await supabase.from("motifs").select("*");
	const { data: sz } = await supabase.from("sizes").select("*");
	typesData = t || [];
	motifsData = m || [];
	sizesData = sz || [];

	const { data: s } = await supabase.from("settings").select("*").single();
	if (s) settings = s;

	// Hierarchical Helper: Sort categories into a flat list with levels
	const buildCategoryTree = (
		list: any[],
		parentId = null,
		depth = 0,
		currentPath = "",
	): any[] => {
		let result: any[] = [];
		list.filter((item) => item.parent_id === parentId).forEach((item) => {
			const fullPath = currentPath
				? `${currentPath} > ${item.name}`
				: item.name;
			result.push({ ...item, depth, fullPath });
			const children = buildCategoryTree(
				list,
				item.id,
				depth + 1,
				fullPath,
			);
			result = result.concat(children);
		});
		return result;
	};

	hierarchicalTypes = buildCategoryTree(typesData);

	// Get category by Path (New) or ID (Legacy)
	targetType = hierarchicalTypes.find(
		(t) => t.fullPath === typeFilter || t.id === typeFilter,
	);
	const targetMotif = motifsData.find((m) => m.name === motifFilter);

	console.log("DEBUG: DB Match", { targetType, targetMotif });

	// Get active ancestry path for conditional visibility
	const getAncestry = (list: any[], currentId: any): any[] => {
		if (!currentId) return [];
		const item = list.find((t) => t.id === currentId);
		if (!item) return [];
		return [item.id, ...getAncestry(list, item.parent_id)];
	};

	activePathIds = getAncestry(typesData, targetType?.id || null);

	// Build the query
	let query = supabase
		.from("products")
		.select(
			"*, types(name), product_motifs(motif_id, motifs(name)), product_categories(category_id, types(name))",
		);

	if (targetType) {
		// If filtering by type, we check both the main type_id AND the join table for any level matches
		// Note: Filtering specifically by the join table can be done via 'product_categories.category_id'
		// but for simplicity here we will fetch then filter in JS to handle hierarchical "OR" logic easily
	}

	if (sizeFilter) query = query.contains("sizes", [sizeFilter]); // Proper array filter

	const { data: p, error: pError } = await query.order("created_at", {
		ascending: false,
	});
	productsData = p || [];

	if (pError) console.error("Filter Query Error:", pError);
} else {
	// Fallback to mock data if supabase is not configured
	const { products: mockProducts } = await import("../data/products");
	productsData = mockProducts.map((p) => ({
		...p,
		types: { name: p.type },
		product_motifs: [{ motifs: { name: p.motif } }],
		image_url: p.imageUrl,
		wa_number: p.waNumber,
		tokopedia_url: p.tokopediaUrl,
	}));

	const uniqueTypes = [...new Set(mockProducts.map((p) => p.type))];
	typesData = uniqueTypes.map((t) => ({ name: t }));

	uniqueTypes.forEach((t) => {
		hierarchicalTypes.push({ name: t, depth: 0, parent_id: null });
	});

	const uniqueMotifs = [...new Set(mockProducts.map((p) => p.motif))];
	motifsData = uniqueMotifs.map((m) => ({ name: m }));

	const mockSizes = ["S", "M", "L", "XL", "XXL", "All Size"];
	sizesData = mockSizes.map((s) => ({ name: s }));

	// Populate targetType for mock data
	targetType = hierarchicalTypes.find(
		(t) => t.fullPath === typeFilter || t.name === typeFilter,
	);
}

const waBaseUrl = "https://wa.me/";

// Final check to handle joined data format variations and comprehensive search
const filteredProducts =
	productsData?.filter((p: any) => {
		// Hierarchical Type Match: Check if the filtered ID matches ANY associated category
		const productCategoryIds =
			p.product_categories?.map((pc: any) => pc.category_id) || [];
		if (p.type_id) productCategoryIds.push(p.type_id);

		// Also keep names for legacy/search support if needed, but ID is primary
		const productCategoryNames =
			p.product_categories?.map((pc: any) => pc.types?.name) || [];
		if (p.types?.name) productCategoryNames.push(p.types.name);

		// Match by ID primarily (from resolved targetType), fallback to Path string
		const typeMatch =
			!typeFilter ||
			productCategoryIds.includes(targetType?.id) ||
			productCategoryNames.includes(typeFilter);

		// Motif Filter
		const productMotifs =
			p.product_motifs?.map((pm: any) => pm.motifs?.name) || [];
		const motifMatch = !motifFilter || productMotifs.includes(motifFilter);

		// Search Query
		let searchMatch = true;
		if (searchQuery) {
			const q = searchQuery.toLowerCase().trim();
			const keywords = q.split(/\s+/).filter((kw) => kw.length > 0);

			// All keywords must match at least one search surface (AND logic between keywords)
			searchMatch = keywords.every((kw) => {
				const nameMatch = p.name?.toLowerCase().includes(kw);
				const codeMatch = p.code?.toLowerCase().includes(kw);
				const motifMatch = productMotifs.some((m: any) =>
					m?.toLowerCase().includes(kw),
				);
				const categoryMatch = productCategoryNames.some((c: any) =>
					c?.toLowerCase().includes(kw),
				);

				return nameMatch || codeMatch || motifMatch || categoryMatch;
			});
		}

		// Price Range Filter
		const priceMatch =
			(!minPrice || p.price >= minPrice) &&
			(!maxPrice || p.price <= maxPrice);

		return typeMatch && motifMatch && searchMatch && priceMatch;
	}) || [];

// Sort Logic
const sortedProducts = filteredProducts.sort((a: any, b: any) => {
	// Priority 1: Availability (Active first)
	if (a.is_active !== b.is_active) {
		return a.is_active ? -1 : 1;
	}

	// Priority 2: User requested sort
	switch (sort) {
		case "price-asc":
			return a.price - b.price;
		case "price-desc":
			return b.price - a.price;
		case "alphabetical":
			return (a.name || "").localeCompare(b.name || "");
		case "newest":
		default:
			return (
				new Date(b.created_at).getTime() -
				new Date(a.created_at).getTime()
			);
	}
});
