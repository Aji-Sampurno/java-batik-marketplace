---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { apiFetch } from "../lib/api";
import ProductCard from "../components/ProductCard.astro";

const { searchParams } = Astro.url;
const typeFilter = searchParams.get("type");
const motifFilter = searchParams.get("motif");
const sizeFilter = searchParams.get("size"); // New size filter
const searchQuery = searchParams.get("q");
const minPrice = searchParams.get("minP")
	? Number(searchParams.get("minP"))
	: null;
const maxPrice = searchParams.get("maxP")
	? Number(searchParams.get("maxP"))
	: null;
const sort = searchParams.get("sort") || "newest";

const getSortUrl = (newSort: string) => {
	const p = new URLSearchParams(searchParams);
	p.set("sort", newSort);
	p.delete("page"); // Reset to page 1 when sorting changes
	return `?${p.toString()}`;
};

// Moved helper getProductDisplaySizes logic to inside ProductCard component for DRY modularity

console.log("DEBUG: products.astro", {
	typeFilter,
	motifFilter,
	sizeFilter,
	searchQuery,
	minPrice,
	maxPrice,
	sort,
});

// Fetch Types and Motifs for the filter UI
let typesData: any[] = [];
let motifsData: any[] = [];
let sizesData: any[] = [];
let productsData: any[] = [];
let hierarchicalTypes: any[] = [];
let activePathIds: any[] = [];
let targetType: any = null;
let settings: any = { contact_whatsapp: "628123456789" };

try {
	const tRes = await apiFetch<any>("types");
	typesData = tRes?.data || tRes || [];

	const mRes = await apiFetch<any>("motifs");
	motifsData = mRes?.data || mRes || [];

	const szRes = await apiFetch<any>("sizes");
	sizesData = szRes?.data || szRes || [];

	const sRes = await apiFetch<any>("settings");
	const s = sRes?.data || sRes;
	if (s) settings = s;

	// Hierarchical Helper: Sort categories into a flat list with levels
	const buildCategoryTree = (
		list: any[],
		parentId = null,
		depth = 0,
		currentPath = "",
	): any[] => {
		let result: any[] = [];
		list.filter((item) => item.parent_id === parentId).forEach((item) => {
			const fullPath = currentPath
				? `${currentPath} > ${item.name}`
				: item.name;
			result.push({ ...item, depth, fullPath });
			const children = buildCategoryTree(
				list,
				item.id,
				depth + 1,
				fullPath,
			);
			result = result.concat(children);
		});
		return result;
	};

	hierarchicalTypes = buildCategoryTree(typesData);

	// Get category by Path (New) or ID (Legacy)
	targetType = hierarchicalTypes.find(
		(t) => t.fullPath === typeFilter || t.id === typeFilter,
	);
	const targetMotif = motifsData.find((m) => m.name === motifFilter);

	console.log("DEBUG: DB Match", { targetType, targetMotif });

	// Get active ancestry path for conditional visibility
	const getAncestry = (list: any[], currentId: any): any[] => {
		if (!currentId) return [];
		const item = list.find((t) => t.id === currentId);
		if (!item) return [];
		return [item.id, ...getAncestry(list, item.parent_id)];
	};

	activePathIds = getAncestry(typesData, targetType?.id || null);
} catch (e: any) {
	console.error("API Fetch Error, using mock fallback:", e.message);
	// Fallback mock data omitted for brevity but structure maintained downstairs if needed
}

// PREPARE PAGINATION STATE
const itemsPerPage = 12;
const currentPage = Number(searchParams.get("page") || "1");

// Placeholder state that gets hydrated either by API or Mock Fallback
let totalItems = 0;
let totalPages = 1;
let paginatedProducts: any[] = [];

// 1. BUILD NATIVE QUERY FOR BACKEND PAGINATION & FILTERING
const productParams = new URLSearchParams();
productParams.set("page", String(currentPage));
productParams.set("per_page", String(itemsPerPage));
if (typeFilter) productParams.set("type", typeFilter);
if (motifFilter) productParams.set("motif", motifFilter);
if (sizeFilter) productParams.set("size", sizeFilter);
if (searchQuery) productParams.set("search", searchQuery);
if (minPrice) productParams.set("min_price", String(minPrice));
if (maxPrice) productParams.set("max_price", String(maxPrice));
productParams.set("sort", sort);

try {
	// EXECUTE BACKEND FILTERING (Ultra Fast - transfers max 12 items)
	const pRes = await apiFetch<any>(`products?${productParams.toString()}`);
	paginatedProducts = pRes?.data || [];
	
	// Extract standard Laravel Paginator / JsonResource meta
	const meta = pRes?.meta || pRes;
	totalItems = Number(meta?.total || paginatedProducts.length);
	totalPages = Number(meta?.last_page || Math.ceil(totalItems / itemsPerPage));
} catch (pError: any) {
	console.error("Backend Product Fetch Failed, falling back to mock filtering:", pError.message);
	// DYNAMIC MOCK FALLBACK (Only runs if internet/backend is fully offline)
	const { products: mockProducts } = await import("../data/products");
	const rawMock = mockProducts.map((p) => ({
		...p,
		types: { name: p.type },
		product_motifs: [{ motifs: { name: p.motif } }],
		image_url: p.imageUrl,
	}));
	
	// Minimal client-side mock filtering purely for local-dev safety
	const filteredMock = rawMock.filter(p => {
		const typeM = !typeFilter || p.type === typeFilter;
		const searchM = !searchQuery || p.name.toLowerCase().includes(searchQuery.toLowerCase());
		return typeM && searchM;
	});

	totalItems = filteredMock.length;
	totalPages = Math.ceil(totalItems / itemsPerPage);
	paginatedProducts = filteredMock.slice((currentPage - 1) * itemsPerPage, currentPage * itemsPerPage);
}

// SAFETY CLAMP: Final guarantee that page remains bound
const safePage = (totalPages > 0 && currentPage > totalPages) ? 1 : currentPage;

const waBaseUrl = "https://wa.me/";

// Page Generator Helper for Footer UI
const getPageUrl = (pageNum: number) => {
	const p = new URLSearchParams(searchParams);
	p.set("page", String(pageNum));
	return `?${p.toString()}`;
};
---

<Layout title="Koleksi Eksklusif Galeri">
	<section style="padding: 90px 0 80px 0; background: #fff;">
