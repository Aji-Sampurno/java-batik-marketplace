							typeFilter && (
								<input
									type="hidden"
									name="type"
									value={typeFilter}
								/>
							)
						}
						{
							motifFilter && (
								<input
									type="hidden"
									name="motif"
									value={motifFilter}
								/>
							)
						}
						{
							sizeFilter && (
								<input
									type="hidden"
									name="size"
									value={sizeFilter}
								/>
							)
						}
						{
							minPrice && (
								<input
									type="hidden"
									name="minP"
									value={minPrice}
								/>
							)
						}
						{
							maxPrice && (
								<input
									type="hidden"
									name="maxP"
									value={maxPrice}
								/>
