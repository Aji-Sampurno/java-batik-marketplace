									>
										{s.name}
									</a>
								))
							}
						</div>
					</div>

					<details class="filter-group">
						<summary
							style="display: flex; justify-space-between; align-items: center; cursor: pointer; list-style: none; outline: none; display: flex; justify-content: space-between;"
						>
							<span
								class="text-uppercase"
								style="font-size: 0.75rem; color: var(--color-accent); font-weight: 600; letter-spacing: 2px;"
								>Motif Batik</span
							>
							<svg
								class="chevron"
								width="12"
								height="12"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								style="opacity: 0.5; transition: transform 0.3s ease;"
								><polyline points="6 9 12 15 18 9"
								></polyline></svg
							>
						</summary>
						<div
							style="display: flex; flex-direction: column; gap: 0.4rem; padding: 0.6rem 0 1rem 0;"
						>
							<a
								href={`/products?${new URLSearchParams({ ...Object.fromEntries(searchParams), motif: "", page: "1" })}`}
								class={!motifFilter
									? "active-filter"
									: "filter-link"}>Semua Motif</a
							>
							{
								motifsData?.map((m) => (
									<a
										href={`/products?${new URLSearchParams({ ...Object.fromEntries(searchParams), motif: m.name, page: "1" })}`}
										class={
											motifFilter === m.name
												? "active-filter"
												: "filter-link"
										}
									>
										{m.name}
									</a>
								))
							}
						</div>
					</details>

					<div
						style="margin-top: var(--spacing-lg); padding-top: var(--spacing-lg); border-top: 1px solid var(--color-border);"
					>
						<p
							style="font-size: 0.75rem; opacity: 0.4; font-style: italic;"
						>
							Menampilkan {totalItems} produk dari koleksi
							kami.
						</p>
					</div>
				</aside>

				<!-- Product Grid -->
				<main>
					<div
						style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;"
					>
						<div class="results-info">
							Menampilkan <strong
								>{totalItems}</strong
							> produk
						</div>
						<div class="sorting-controls">
							<span class="sort-label">Urutkan:</span>
							<div class="custom-dropdown" id="sortDropdown">
								<button class="dropdown-trigger" type="button">
									<span class="current-label">
										{sort === "newest" && "Terbaru"}
										{
											sort === "price-asc" &&
												"Harga: Terendah"
										}
										{
											sort === "price-desc" &&
												"Harga: Tertinggi"
										}
										{
											sort === "alphabetical" &&
												"Nama: A - Z"
										}
									</span>
									<svg
										class="chevron"
										width="12"
										height="12"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="3"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path d="M6 9l6 6 6-6"></path></svg
									>
								</button>
								<div class="dropdown-menu">
									<a
										href={getSortUrl("newest")}
										class={`dropdown-item ${sort === "newest" ? "active" : ""}`}
									>
										<svg
											width="14"
											height="14"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											><circle cx="12" cy="12" r="10"
											></circle><path d="M12 6v6l4 2"
											></path></svg
										>
										Terbaru
									</a>
									<a
										href={getSortUrl("price-asc")}
										class={`dropdown-item ${sort === "price-asc" ? "active" : ""}`}
									>
										<svg
											width="14"
											height="14"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											><path d="M12 19V5M5 12l7-7 7 7"
											></path></svg
										>
										Harga: Terendah
									</a>
									<a
										href={getSortUrl("price-desc")}
										class={`dropdown-item ${sort === "price-desc" ? "active" : ""}`}
									>
										<svg
											width="14"
											height="14"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											><path d="M12 5v14M5 12l7 7 7-7"
											></path></svg
										>
										Harga: Tertinggi
									</a>
									<a
										href={getSortUrl("alphabetical")}
										class={`dropdown-item ${sort === "alphabetical" ? "active" : ""}`}
									>
										<svg
											width="14"
											height="14"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											><path
												d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
											></path><polyline
												points="7 10 12 15 17 10"
											></polyline><line
												x1="12"
												y1="15"
												x2="12"
												y2="3"></line><path
												d="M11 5h10M11 9h10M11 13h10M11 17h10M11 21h10"
											></path></svg
										>
										Nama: A-Z
									</a>
								</div>
							</div>
						</div>
					</div>
					<div class="product-grid" style="margin-top: 0;">
						{
							paginatedProducts.map((p, index) => (
								<ProductCard product={p} index={index} settings={settings} />
							))
						}
					</div>

					<!-- Dynamic Infinite Scroll Loading Trigger -->
					{totalPages > 1 && (
						<div id="infinite-scroll-loader" style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3rem 0; min-height: 100px; text-align: center;">
							<div id="loading-spinner" style="display: none; flex-direction: column; align-items: center; gap: 1rem;">
								<div style="width: 30px; height: 30px; border: 3px solid rgba(140,120,81,0.1); border-top-color: var(--color-accent); border-radius: 50%; animation: spin 0.8s linear infinite;"></div>
								<p style="font-size: 0.7rem; letter-spacing: 1px; text-transform: uppercase; color: var(--color-accent); font-weight: 600; opacity: 0.7;">Memuat Koleksi...</p>
							</div>
							
							<!-- Fallback manual button just in case -->
							<button id="manual-load-more" style="padding: 12px 24px; background: white; border: 1px solid #e2e8f0; border-radius: 8px; font-family: var(--font-main); font-size: 0.8rem; font-weight: 600; cursor: pointer; display: none; color: var(--color-text); transition: all 0.2s;">Tampilkan Lebih Banyak</button>
							
							<!-- Sentinel purely for IntersectionObserver hook -->
							<div id="infinite-scroll-sentinel" style="height: 1px; width: 100%;"></div>
						</div>
					)}

					<style>
						@keyframes spin {
							to { transform: rotate(360deg); }
						}
					</style>

					<script is:inline define:vars={{ totalPages, currentPage, queryParamsString: productParams.toString() }}>
						document.addEventListener('DOMContentLoaded', () => {
							let currPage = parseInt(currentPage);
							const tPages = parseInt(totalPages);
							
							if (tPages <= 1) return;

							const sentinel = document.getElementById('infinite-scroll-sentinel');
							const grid = document.querySelector('.product-grid');
							const spinner = document.getElementById('loading-spinner');
							const manualBtn = document.getElementById('manual-load-more');
							
							let isLoading = false;

							const loadNextPage = async () => {
								if (isLoading || currPage >= tPages) return;
								
								isLoading = true;
								spinner.style.display = 'flex';
								manualBtn.style.display = 'none';

								currPage += 1;
								
								try {
									// Construct partial fetching URL targeting our newly minted Astro endpoint!
									const baseParams = new URLSearchParams(queryParamsString);
									baseParams.set('page', currPage.toString());
									
									const fetchUrl = `/partial/products?${baseParams.toString()}`;
									const response = await fetch(fetchUrl);
									if (response.ok) {
										const html = await response.text();
										if(html.trim().length > 0) {
											// Inject new product cards smoothly
											grid.insertAdjacentHTML('beforeend', html);
											
											// Re-run intersection reveal hooks defined globally in Layout.astro
											if (typeof window !== 'undefined' && document.querySelectorAll) {
												const newElements = grid.querySelectorAll('.product-card:not(.active)');
												const obs = new IntersectionObserver((entries) => {
													entries.forEach(e => {
														if(e.isIntersecting) {
															setTimeout(() => e.target.classList.add('active'), e.target.dataset.delay || 0);
															obs.unobserve(e.target);
														}
													});
												});
												newElements.forEach(el => obs.observe(el));
											}
										}
									}
								} catch (err) {
									console.error('Infinite Scroll Error:', err);
									manualBtn.style.display = 'block';
								} finally {
									isLoading = false;
									spinner.style.display = 'none';
									
									// If reached the end, remove loader entirely
									if (currPage >= tPages) {
										const loader = document.getElementById('infinite-scroll-loader');
										if(loader) loader.style.display = 'none';
									}
								}
							};

							// Set up intersection observer to automatically trigger load at the bottom!
							const io = new IntersectionObserver((entries) => {
								if (entries[0].isIntersecting) {
									loadNextPage();
								}
							}, { rootMargin: '200px' }); // Trigger early 200px before bottom hits

							if (sentinel) {
								io.observe(sentinel);
							}

							manualBtn.addEventListener('click', loadNextPage);
						});
					</script>

					{
						totalItems === 0 && (
