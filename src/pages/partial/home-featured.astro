---
export const prerender = false;
import { apiFetch } from "../../lib/api";

let featuredProducts: any[] = [];
try {
	const pRes = await apiFetch<any>("products?per_page=3");
	featuredProducts = pRes?.data || pRes || [];
} catch (e: any) {
	console.error("API Fetch Error, fallback:", e.message);
	const { products: mockProducts } = await import("../../data/products");
	featuredProducts = mockProducts.slice(0, 3).map((p) => ({
		...p,
		types: { name: p.type },
		product_motifs: [{ motifs: { name: p.motif } }],
		image_url: p.imageUrl,
	}));
}
---

<style is:inline>
	@keyframes fadeInUpLazy {
		from { opacity: 0; transform: translateY(25px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.product-lazy-card {
		animation: fadeInUpLazy 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}
</style>

{
	featuredProducts.map((p, index) => (
		<div
			class="product-card product-lazy-card"
			style={`${!p.is_active ? "opacity: 0.8;" : "opacity: 0;"} animation-delay: ${index * 120}ms;`}
		>
			<div
				class="product-image"
				style="position: relative;"
			>
				<a href={`/products/${p.id}`}>
					<img
						src={
							p.image_url ||
							"https://via.placeholder.com/400x600?text=Batik"
						}
						alt={p.name}
						loading="lazy"
						class={
							!p.is_active
								? "out-of-stock-img"
								: ""
						}
					/>
					{!p.is_active && (
						<div class="ribbon-wrapper">
							<div class="ribbon">HABIS</div>
						</div>
					)}
				</a>
			</div>
			<div class="product-info">
				<p
					class="text-uppercase opacity-50"
					style="font-size: 0.65rem;"
				>
					{(p.type?.name || p.types?.name || "-")} •{" "}
					{(p.motifs?.map((m: any) => m.name).join(", ") || p.product_motifs?.map((pm: any) => pm.motifs?.name).join(", ") || "-")}
				</p>
				<h3 style="font-family: var(--font-main); font-weight: 500;">
					<a
						href={`/products/${p.id}`}
						style="color: inherit; text-decoration: none;"
					>
						{p.name}
					</a>
				</h3>
				<p class="price-tag">
					{p.is_active ? (
						<>
							{p.original_price && p.original_price > p.price && (
								<span style="text-decoration: line-through; color: #999; font-size: 0.8rem; margin-right: 0.5rem;">
									Rp {Number(p.original_price).toLocaleString("id-ID")}
								</span>
							)}
							<span>
								{(() => {
									let displayPrice = `Rp ${Number(p.price).toLocaleString("id-ID")}`;
									const variants = p.variants || p.product_variants || [];
									if(variants && variants.length > 0) {
										const vPrices = variants.map((v:any) => v.price);
										const vMin = Math.min(...vPrices);
										if (vMin > 0) {
											displayPrice = `Rp ${vMin.toLocaleString("id-ID")}`;
										}
									}
									return displayPrice;
								})()}
							</span>
						</>
					) : (
						<span style="color: #b91c1c; font-weight: 700;">
							STOK HABIS
						</span>
					)}
				</p>
			</div>
		</div>
	))
}
