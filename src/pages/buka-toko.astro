---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { apiFetch, uploadToLaravel } from "../lib/api";
import DeleteConfirmModal from "../components/DeleteConfirmModal.astro";
import AdminProductRow from "../components/AdminProductRow.astro";

// Check for session (Authentication Gate)
const session = Astro.cookies.get("admin_session");
if (session?.value !== "authenticated") {
	return Astro.redirect("/login");
}

const publicApiUrl = import.meta.env.PUBLIC_API_URL || "https://api.katalog.batik.gooproper.id/api";

// Handle Logout & Search
const { searchParams } = Astro.url;
if (searchParams.get("logout")) {
	Astro.cookies.delete("admin_session");
	return Astro.redirect("/login");
}
const adminSearchQuery = searchParams.get("q");

// Fetch Types and Motifs for the dropdowns
let types: any[] = [];
let motifs: any[] = [];
let sizesData: any[] = [];
let productsData: any[] = [];
let settings: any = { site_name: "Batik Nusantara" };
let totalItems = 0;
let totalPages = 1;
let activeCount = 0;
let adminPage = 1;

// Blocking API requests in the Dashboard landing have been migrated to client-side
// async loaders to secure instantaneous rendering of the menu shell.


// Hierarchical Helper: Sort categories into a flat list with levels
const buildCategoryTree = (list: any[], parentId = null, depth = 0): any[] => {
	let result: any[] = [];
	list.filter((item) => item.parent_id === parentId).forEach((item) => {
		result.push({ ...item, depth });
		const children = buildCategoryTree(list, item.id, depth + 1);
		result = result.concat(children);
	});
	return result;
};

const hierarchicalTypes = buildCategoryTree(types);

let message = "";
let isError = false;

// Handle Form Submission (Server Side)
if (Astro.request.method === "POST") {
	const contentType = Astro.request.headers.get("content-type");
	if (contentType?.includes("form")) {
		try {
			const formData = await Astro.request.formData();
			const action = formData.get("action");

			if (action === "add_product") {
				return Astro.redirect("/buka-toko/tambah-produk");
			}

			if (action === "toggle_status") {
				const id = formData.get("id");
				const current_status =
					formData.get("current_status") === "true";
				await apiFetch(`products/${id}`, {
					method: "PUT",
					body: JSON.stringify({ is_active: !current_status }),
				});
				return Astro.redirect("/buka-toko?success=status");
			}

			if (action === "delete_product") {
				const id = formData.get("id");
				await apiFetch(`products/${id}`, { method: "DELETE" });
				return Astro.redirect("/buka-toko?success=delete");
			}
		} catch (e: any) {
			isError = true;
			message = "Gagal: " + e.message;
		}
	}
}

const success = Astro.url.searchParams.get("success");
if (success === "product") message = "Produk berhasil ditambahkan!";
if (success === "type") message = "Jenis produk baru berhasil disimpan!";
if (success === "motif") message = "Motif baru berhasil ditambahkan!";
if (success === "settings") message = "Identitas website berhasil diperbarui!";
if (success === "status") message = "Status visibilitas produk diperbarui!";
if (success === "delete") message = "Produk berhasil dihapus!";
if (success === "delete_type") message = "Jenis produk berhasil dihapus!";
if (success === "delete_motif") message = "Motif berhasil dihapus!";
if (success === "size") message = "Ukuran berhasil ditambahkan!";
if (success === "deleted") message = "Data berhasil dihapus!";
---

<Layout title={`Admin Panel - ${settings?.site_name || "Batik Nusantara"}`}>
	<section
		style="padding: 130px 0 var(--spacing-2xl) 0; background: #fdfcfb; min-height: 100vh;"
	>
		<div class="container">
			<div
				class="admin-header"
				style="border-bottom: none; margin-bottom: var(--spacing-sm); margin-top: 0;"
			>
				<div
					style="display: flex; align-items: center; gap: var(--spacing-md);"
				>
					<div>
						<h1
							class="text-uppercase"
							style="font-size: 1.4rem; margin: 0; font-weight: 600;"
						>
							{settings?.site_name || "Batik Nusantara"} Dashboard
						</h1>
						<p style="font-size: 0.85rem; opacity: 0.5;">
							Kelola identitas dan katalog batik Anda.
						</p>
					</div>
				</div>
			</div>

			<!-- Overview Stats -->
			<div
				style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--spacing-lg); margin-bottom: var(--spacing-xl);"
			>
				<div
					class="glass"
					style="padding: var(--spacing-lg); border-radius: var(--radius-md); border-left: 4px solid var(--color-accent);"
				>
					<p
						class="text-uppercase opacity-50"
						style="font-size: 0.65rem;"
					>
						Total Produk
					</p>
					<h2 style="font-size: 2rem; margin: 0;">
						<span id="stat-active-count">--</span>
						<span style="font-size: 1rem; opacity: 0.4;"
							>/ <span id="stat-total-count">--</span></span
						>
					</h2>
				</div>
				<div
					class="glass"
					style="padding: var(--spacing-lg); border-radius: var(--radius-md); border-left: 4px solid #03ac0e;"
				>
					<p
						class="text-uppercase opacity-50"
						style="font-size: 0.65rem;"
					>
						Kategori Jenis
					</p>
					<h2 style="font-size: 2rem; margin: 0;">
						<span id="stat-types-count">--</span>
					</h2>
				</div>
				<div
					class="glass"
					style="padding: var(--spacing-lg); border-radius: var(--radius-md); border-left: 4px solid #3b82f6;"
				>
					<p
						class="text-uppercase opacity-50"
						style="font-size: 0.65rem;"
					>
						Total Motif
					</p>
					<h2 style="font-size: 2rem; margin: 0;">
						<span id="stat-motifs-count">--</span>
					</h2>
				</div>
				<div
					class="glass"
					style="padding: var(--spacing-lg); border-radius: var(--radius-md); border-left: 4px solid #d97706;"
				>
					<p
						class="text-uppercase opacity-50"
						style="font-size: 0.65rem;"
					>
						Total Pra-Produk
					</p>
					<h2 style="font-size: 2rem; margin: 0;">
						<span id="stat-praproduk-count">--</span>
					</h2>
				</div>
			</div>

			{
				message && (
					<div
						class="animate-fade-in"
						style={`padding: 1rem; margin-bottom: 2rem; border-radius: var(--radius-sm); border: 1px solid ${
							isError ? "#ff4d4d" : "#03ac0e"
						}; background: ${
							isError ? "#fff5f5" : "#f5fff5"
						}; color: ${
							isError ? "#ff4d4d" : "#03ac0e"
						}; text-align: center; font-size: 0.9rem; font-weight: 500;`}
					>
						{message}
					</div>
				)
			}

			<div class="admin-main-grid" id="adminMainGrid">
				<!-- List Column -->
				<div>
					<div
						style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-lg); flex-wrap: wrap; gap: 1rem;"
					>
						<h2
							style="font-size: 1.1rem; font-weight: 600; margin: 0;"
						>
							Daftar Produk Terdaftar
						</h2>

						<!-- Admin Search -->
						<form
							method="GET"
							style="position: relative; flex: 1; min-width: 200px; max-width: 400px;"
						>
							<input
								name="q"
								type="text"
								value={adminSearchQuery || ""}
								placeholder="Cari nama, SKU, atau motif..."
								style="width: 100%; padding: 0.6rem 2.5rem 0.6rem 0.8rem; border: 1px solid #ddd; border-radius: var(--radius-sm); font-size: 0.85rem;"
							/>
							<button
								type="submit"
								style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; opacity: 0.4; cursor: pointer;"
							>
								<svg
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									><circle cx="11" cy="11" r="8"
									></circle><line
										x1="21"
										y1="21"
										x2="16.65"
										y2="16.65"></line>
								</svg>
							</button>
						</form>

						<span
							class="text-uppercase opacity-50"
							style="font-size: 0.65rem; font-weight: 600; background: #f1f5f9; padding: 4px 8px; border-radius: 4px; color: #475569;"
							><span id="table-total-count">--</span> Total Produk</span
						>
					</div>

					<div
						style="background: white; border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow-x: auto; box-shadow: var(--shadow-sm);"
					>
						<table style="width: 100%; border-collapse: collapse;">
							<thead>
								<tr
									style="background: #f9f9f9; border-bottom: 1px solid var(--color-border); text-align: left;"
									class="text-uppercase"
								>
									<th
										style="padding: 1rem; font-size: 0.65rem; opacity: 0.6;"
										>Produk</th
									>
									<th
										style="padding: 1rem; font-size: 0.65rem; opacity: 0.6;"
										>Kategori</th
									>
									<th
										style="padding: 1rem; font-size: 0.65rem; opacity: 0.6;"
										>Harga</th
									>
									<th
										style="padding: 1rem; font-size: 0.65rem; opacity: 0.6; text-align: center;"
										>Status</th
									>
									<th
										style="padding: 1rem; font-size: 0.65rem; opacity: 0.6; text-align: center;"
										>Aksi</th
									>
								</tr>
							</thead>
							<tbody id="admin-tbody">
								<!-- Initial Loading Placeholder directly rendered for fast first paint -->
								<tr id="initial-loading-indicator">
									<td colspan="5" style="text-align: center; padding: 4rem; color: #64748b;">
										<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem;">
											<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="animation: spin 1s linear infinite;"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg>
											<p style="font-weight: 500; font-size: 0.9rem;">Memuat data katalog...</p>
										</div>
									</td>
								</tr>
								
								<!-- Secret Sentinel row for Infinite Scroll logic -->
								<tr id="sentinel-row" style="opacity: 0; height: 1px; pointer-events: none; display: none;">
									<td colspan="5"></td>
								</tr>
							</tbody>
						</table>
						<!-- Empty State Message hidden by default -->
						<div id="empty-state-message" style="display: none; padding: 3rem; text-align: center; opacity: 0.4;">
							Belum ada produk.
						</div>

						<!-- Administrative Infinite Scroll & Initial Hydration Controls -->
						<div id="admin-scroll-loader" style="display: none; text-align: center; padding: 1.5rem; border-top: 1px solid #f0f0f0; background: #fcfcfc; border-bottom-left-radius: var(--radius-md); border-bottom-right-radius: var(--radius-md);">
							<div id="admin-spinner" style="display: flex; justify-content: center; align-items: center; gap: 0.5rem;">
								<div style="width: 20px; height: 20px; border: 2px solid #eee; border-top-color: #0f172a; border-radius: 50%; animation: spin 0.7s linear infinite;"></div>
								<span style="font-size: 0.75rem; color: #64748b; font-weight: 500;">Memuat lebih banyak...</span>
							</div>
							<button id="admin-load-more" style="padding: 8px 16px; background: white; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 0.75rem; color: #475569; font-weight: 600; cursor: pointer; display: none; margin: 0 auto;">Tampilkan Lebih Banyak</button>
						</div>

						<style>
							@keyframes spin { to { transform: rotate(360deg); } }
						</style>

						<script is:inline define:vars={{ publicApiUrl, adminSearchQuery }}>
							document.addEventListener('DOMContentLoaded', () => {
								const initialIndicator = document.getElementById('initial-loading-indicator');
								const emptyState = document.getElementById('empty-state-message');
								const sentinel = document.getElementById('sentinel-row');
								const scrollLoader = document.getElementById('admin-scroll-loader');
								const spinner = document.getElementById('admin-spinner');
								const manualBtn = document.getElementById('admin-load-more');
								
								// STAT ELEMENTS
								const statActive = document.getElementById('stat-active-count');
								const statTotal = document.getElementById('stat-total-count');
								const tableTotal = document.getElementById('table-total-count');
								const statPraproduk = document.getElementById('stat-praproduk-count');
								
								let currPage = 0; 
								let totalPages = 1;
								let isLoading = false;
								
								// Setup intersection observer 
								const observer = new IntersectionObserver((entries) => {
									if (entries[0].isIntersecting && currPage > 0 && currPage < totalPages) {
										loadMoreRows();
									}
								}, { rootMargin: '200px' });

								const loadMoreRows = async () => {
									if (isLoading || (currPage > 0 && currPage >= totalPages)) return;
									
									isLoading = true;
									if(currPage > 0) {
										if(scrollLoader) scrollLoader.style.display = 'block';
									}
									
									const targetPage = currPage + 1;
									
									try {
										const partialUrl = `/partial/admin-products?page=${targetPage}${adminSearchQuery ? `&q=${encodeURIComponent(adminSearchQuery)}` : ''}`;
										const res = await fetch(partialUrl);
										
										if (res.ok) {
											const html = await res.text();
											const hasContent = html.trim().length > 0;
											
											// If this was the very first load, wipe the initial spinner indicator
											if (currPage === 0) {
												if(initialIndicator) initialIndicator.style.display = 'none';
												
												if (!hasContent) {
													if(emptyState) emptyState.style.display = 'block';
												} else {
													// Reveal and attach intersection observer to sentinel
													if(sentinel) {
														sentinel.style.display = 'table-row';
														observer.observe(sentinel);
													}
												}
											}
											
											if(hasContent) {
												sentinel.insertAdjacentHTML('beforebegin', html);
											}
											
											currPage = targetPage;
										}
									} catch (err) {
										console.error('Dashboard Stream Error:', err);
										if(manualBtn) manualBtn.style.display = 'block';
									} finally {
										isLoading = false;
										
										if (currPage >= totalPages) {
											if(scrollLoader) scrollLoader.style.display = 'none';
										}
									}
								};
								
								// Delegate event listener for manual stock check
								document.addEventListener('click', async (e) => {
									if (e.target && e.target.classList.contains('btn-cek-stok')) {
										const btn = e.target;
										const row = btn.closest('.admin-product-row');
										if (!row) return;

										const kodeitem = row.getAttribute('data-kodeitem');
										const currentStock = parseInt(row.getAttribute('data-stock') || '0', 10);
										const productId = row.getAttribute('data-product-id');
										
										if (!kodeitem || kodeitem === '-' || kodeitem === 'null') {
											alert("Kode item tidak valid untuk cek stok.");
											return;
										}

										const syncMsg = row.querySelector('.sync-msg');
										const btnSync = row.querySelector('.btn-sync-stock');

										btn.disabled = true;
										btn.innerText = 'Mengecek...';
										syncMsg.style.display = 'none';
										btnSync.style.display = 'none';

										try {
											const url = `https://noir.grace.gracianna.web.id/api/v1/beli1?per_page=20&q=${encodeURIComponent(kodeitem)}`;
											const res = await fetch(url);
											const json = await res.json();
											
											if (json.success && json.data && json.data.length > 0) {
												const item = json.data.find(i => i.kode === kodeitem || i.kodeitem === kodeitem);
												if (item) {
													let erpStock = 0;
													if (item.details && Array.isArray(item.details)) {
														erpStock = item.details.reduce((sum, d) => sum + parseInt(d.stok || 0, 10), 0);
													}
													
													if (erpStock !== currentStock) {
														btn.style.display = 'none';
														syncMsg.style.display = 'inline-block';
														syncMsg.style.color = '#b91c1c';
														syncMsg.innerText = `ERP: ${erpStock} (Web: ${currentStock})`;
														
														btnSync.style.display = 'inline-block';
														btnSync.onclick = async () => {
															btnSync.disabled = true;
															btnSync.innerText = 'Syncing...';
															try {
																const updateUrl = `${publicApiUrl}/products/${productId}`;
																const updateRes = await fetch(updateUrl, {
																	method: 'PUT',
																	headers: {
																		'Content-Type': 'application/json',
																		'Accept': 'application/json'
																	},
																	body: JSON.stringify({ _force_sync: true }) 
																});
																
																if (updateRes.ok) {
																	btnSync.innerText = 'Tersinkronisasi';
																	btnSync.style.background = '#10b981';
																	setTimeout(() => {
																		btnSync.style.display = 'none';
																		syncMsg.style.display = 'none';
																		btn.style.display = 'inline-block';
																		btn.innerText = 'Cek Stok ERP';
																		btn.disabled = false;
																		const stockElement = row.querySelector('[data-stock]');
																		if(stockElement) stockElement.setAttribute('data-stock', erpStock);
																	}, 2000);
																} else {
																	btnSync.innerText = 'Gagal';
																	btnSync.disabled = false;
																}
															} catch(e) {
																btnSync.innerText = 'Gagal';
																btnSync.disabled = false;
															}
														};
													} else {
														btn.innerText = 'Stok Sesuai';
														btn.style.background = '#f0fdf4';
														btn.style.color = '#166534';
														btn.style.borderColor = '#bbf7d0';
														setTimeout(() => {
															btn.innerText = 'Cek Stok ERP';
															btn.style.background = '#f8fafc';
															btn.style.color = '#475569';
															btn.style.borderColor = '#cbd5e1';
															btn.disabled = false;
														}, 3000);
													}
												} else {
													btn.innerText = 'Tdk Ditemukan (List)';
													btn.disabled = false;
													console.log("Kode tidak cocok di hasil:", json.data.map(d=>d.kodeitem));
												}
											} else {
												btn.innerText = 'Tdk Ditemukan (API)';
												btn.disabled = false;
											}
										} catch (err) {
											console.error("Gagal cek stok", err);
											btn.innerText = 'Gagal Cek';
											btn.disabled = false;
										}
									}
								});

								// CLIENT DATA SEQUENCE: Run ALL fetches asynchronously right after DOM is interactive
								const runDashboardHydration = async () => {
									// 1. Trigger table load immediately in background!
									loadMoreRows();
									
									// 2. Fetch stats headers to populate upper count tiles
									try {
										const searchStr = adminSearchQuery ? `&search=${encodeURIComponent(adminSearchQuery)}` : '';
										const metadataUrl = `${publicApiUrl}/products?per_page=12${searchStr}`;
										
										fetch(metadataUrl)
											.then(r => r.json())
											.then(json => {
												if(json && json.meta) {
													totalPages = json.meta.last_page || 1;
													const total = json.meta.total || 0;
													if(tableTotal) tableTotal.innerText = total.toLocaleString('id-ID');
													if(statTotal) statTotal.innerText = total.toLocaleString('id-ID');
													
													// Correct current totalPages so observer bounds are known
												}
											}).catch(e => console.error("Metadata fail:", e));
										
										// Fetch Active Count explicitly
										fetch(`${publicApiUrl}/products?is_active=true&per_page=1`)
											.then(r => r.json())
											.then(json => {
												if(json && json.meta && statActive) {
													statActive.innerText = (json.meta.total || 0).toLocaleString('id-ID');
												}
											}).catch(e => console.error("Active fetch fail:", e));

										// Hydrate Category Count (Recursive tree traversal crawler)
										const statTypes = document.getElementById('stat-types-count');
										fetch(`${publicApiUrl}/types`)
											.then(r => r.json())
											.then(json => {
												const list = Array.isArray(json.data) ? json.data : (Array.isArray(json) ? json : []);
												function countTreeNodes(arr) {
													let count = 0;
													arr.forEach(item => {
														count++;
														if (item.children && Array.isArray(item.children)) {
															count += countTreeNodes(item.children);
														}
													});
													return count;
												}
												if (statTypes) {
													statTypes.innerText = countTreeNodes(list).toLocaleString('id-ID');
												}
											}).catch(e => console.error("Types fetch fail:", e));

										// Hydrate Motif Count (Flat wrapper dataset analyzer)
										const statMotifs = document.getElementById('stat-motifs-count');
										fetch(`${publicApiUrl}/motifs`)
											.then(r => r.json())
											.then(json => {
												const list = Array.isArray(json.data) ? json.data : (Array.isArray(json) ? json : []);
												if (statMotifs) {
													statMotifs.innerText = list.length.toLocaleString('id-ID');
												}
											}).catch(e => console.error("Motifs fetch fail:", e));

										// Fetch external Praproduk Count asynchronously
										fetch("https://noir.grace.gracianna.web.id/api/v1/beli1?per_page=1")
											.then(r => r.json())
											.then(json => {
												if(json && json.meta && statPraproduk) {
													statPraproduk.innerText = (json.meta.total || 0).toLocaleString('id-ID');
												} else if (json.total && statPraproduk) {
													statPraproduk.innerText = (json.total).toLocaleString('id-ID');
												}
											}).catch(e => console.error("Praproduk external fail:", e));
											
									} catch(err) {
										console.error('Stats Orchestration Error:', err);
									}
								};

								// Let the magic begin
								runDashboardHydration();
								
								if(manualBtn) {
									manualBtn.addEventListener('click', loadMoreRows);
								}
							});
						</script>
					</div>
				</div>
			</div>
		</div>
	</section>

