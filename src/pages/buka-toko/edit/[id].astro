---
export const prerender = false;
import Layout from "../../../layouts/Layout.astro";
import { apiFetch, uploadToLaravel } from "../../../lib/api";
import DeleteConfirmModal from "../../../components/DeleteConfirmModal.astro";

// Check for session (Authentication Gate)
const session = Astro.cookies.get("admin_session");
if (session?.value !== "authenticated") {
	return Astro.redirect("/login");
}

const { id } = Astro.params;

let product: any = null;
let types: any[] = [];
let motifs: any[] = [];
let sizesData: any[] = [];
let selectedMotifIds: string[] = [];
let message = "";
let isError = false;

let colorsData: any[] = [];
let selectedColors: string[] = [];

try {
	// Fetch product data
	const pRes = await apiFetch<any>(`products/${id}`);
	product = pRes?.data || pRes;

	if (product) {
		selectedMotifIds = (product.motifs || product.product_motifs || []).map((pm: any) => pm.id || pm.motif_id) || [];
		selectedColors = product.colors || [];
	}

	// Fetch Types, Motifs and Sizes
	const tRes = await apiFetch<any>("types");
	types = tRes?.data || tRes || [];

	const mRes = await apiFetch<any>("motifs");
	motifs = mRes?.data || mRes || [];

	const szRes = await apiFetch<any>("sizes");
	sizesData = szRes?.data || szRes || [];

	const colRes = await apiFetch<any>("colors");
	colorsData = colRes?.data || colRes || [];
} catch (e: any) {
	console.error("API Fetch Error:", e.message);
}

// Hierarchical Helper: Sort categories into a flat list with levels
const buildCategoryTree = (list: any[], parentId = null, depth = 0): any[] => {
	let result: any[] = [];
	list.filter((item) => item.parent_id === parentId).forEach((item) => {
		result.push({ ...item, depth });
		const children = buildCategoryTree(list, item.id, depth + 1);
		result = result.concat(children);
	});
	return result;
};

const hierarchicalTypes = buildCategoryTree(types);

let currentL1CatId = null;
let currentCategoryIds: string[] = [];

if (product) {
	currentCategoryIds = (product.categories || product.product_categories || []).map(
		(pc: any) => pc.id || pc.category_id,
	);
	// Find the Level 1 category among selection
	const l1 = types.find(
		(t) => currentCategoryIds.includes(t.id) && t.parent_id === null,
	);
	currentL1CatId = l1?.id || null;
}

if (!product) {
	return Astro.redirect("/buka-toko");
}

// Handle Form Submission
if (Astro.request.method === "POST") {
	try {
		const formData = await Astro.request.formData();
		const action = formData.get("action");

		if (action === "delete_product") {
			await apiFetch(`products/${id}`, { method: "DELETE" });
			return Astro.redirect("/buka-toko?success=delete");
		}

		const name = formData.get("name");
		const price = formData.get("price");
		const type_id = formData.get("type_id");
		const motif_ids = formData.getAll("motif_ids");
		const colors = formData.getAll("colors");
		const description = formData.get("description");
		const code = formData.get("code");
		const image_files = formData.getAll("image_file") as File[];
		const tokopedia_url = formData.get("tokopedia_url");
		const is_active = formData.get("is_active") === "on";

		let updatedImages = [...(product.images || [])];
		let primaryImageUrl = product.image_url;

		const category_ids = formData.getAll("category_ids");
		const typeId = category_ids[0] || null;
		const selectedType = hierarchicalTypes.find((t: any) => t.id === typeId);
		let folderPath = "products";
		if (selectedType) {
			const slug = selectedType.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
			folderPath = `products/${slug}`;
		}

		// Handle new image uploads
		if (image_files && image_files.length > 0 && image_files[0].size > 0) {
			const newImages: string[] = [];
			for (const file of image_files) {
				if (file.size > 0) {
					const publicUrl = await uploadToLaravel(file, folderPath);
					newImages.push(publicUrl);
				}
			}
			updatedImages = newImages;
			primaryImageUrl = newImages[0];
		}

		const variant_sizes = formData.getAll("variant_size") as string[];
		const variant_prices = formData.getAll("variant_price") as string[];
		const variant_stocks = formData.getAll("variant_stock") as string[];
		const variant_dalamans = formData.getAll("variant_dalaman") as string[];
		const variants = variant_sizes.map((size, index) => ({
			size_name: size,
			price: parseFloat(variant_prices[index] || price?.toString() || "0"),
			stock: parseInt(variant_stocks[index] || "0", 10),
			dalaman: variant_dalamans[index] || null
		}));

		console.log("DEBUG PUT variants payload:", JSON.stringify(variants, null, 2));

		await apiFetch(`products/${id}`, {
			method: "PUT",
			body: JSON.stringify({
				name,
				price,
				type_id: formData.getAll("category_ids")[0] || null,
				category_ids: formData.getAll("category_ids"),
				category_chain: formData.getAll("category_chain"), // Pass dynamic cascade array
				motif_ids,
				colors,
				image_url: primaryImageUrl,
				images: updatedImages,
				tokopedia_url,
				description,
				code,
				original_price: formData.get("original_price"),
				item_code: formData.get("item_code"),
				is_active,
				variants,
			}),
		});

		return Astro.redirect("/buka-toko?success=status"); // Redirect to admin with success
	} catch (e: any) {
		isError = true;
		message = "Gagal memperbarui produk: " + e.message;
	}
}
---

<Layout title={`Edit Produk - ${product.name}`}>
	<section style="padding: 130px 0 var(--spacing-2xl) 0; background: #fdfcfb; min-height: 100vh;">
		<div class="container" style="max-width: 1000px;">
			<div style="margin-bottom: var(--spacing-xl);">
				<h1 class="text-uppercase" style="font-size: 1.5rem; margin: 0; font-weight: 600;">Edit Produk</h1>
				<p style="font-size: 0.8rem; opacity: 0.5;">Ubah detail produk</p>
			</div>

			{
				message && (
					<div
						class="animate-fade-in"
						style={`padding: 1rem; margin-bottom: 2rem; border-radius: var(--radius-sm); border: 1px solid ${
							isError ? "#ff4d4d" : "#03ac0e"
						}; background: ${
							isError ? "#fff5f5" : "#f5fff5"
						}; color: ${
							isError ? "#ff4d4d" : "#03ac0e"
						}; text-align: center; font-size: 0.9rem; font-weight: 500;`}
					>
						{message}
					</div>
				)
			}

			<div
				style="background: white; border: 1px solid var(--color-border); padding: var(--spacing-xl); border-radius: var(--radius-md); box-shadow: var(--shadow-sm);"
			>
				<form
					method="POST"
					enctype="multipart/form-data"
					style="display: flex; flex-direction: column; gap: var(--spacing-lg);"
				>
					<div>
						<label
							class="text-uppercase opacity-50"
							style="font-size: 0.65rem; display: block; margin-bottom: 0.5rem; font-weight: 600;"
							>Nama Produk</label
						>
						<input
							name="name"
							id="product_name_input"
							type="text"
							required
							value={product.name}
							style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: var(--radius-sm);"
						/>
					</div>

					<div
						style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-lg);"
					>
						<div>
							<label
								class="text-uppercase opacity-50"
								style="font-size: 0.65rem; display: block; margin-bottom: 0.5rem; font-weight: 600;"
								>Kode SKU</label
							>
							<input
								name="code"
								id="product_sku_input"
								type="text"
								value={product.code}
								style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: var(--radius-sm);"
							/>
						</div>
						<div>
							<label
								class="text-uppercase opacity-50"
								style="font-size: 0.65rem; display: block; margin-bottom: 0.5rem; font-weight: 600;"
								>Kode Barang (Auto-Name)</label
							>
							<input
								name="item_code"
								id="product_item_code_input"
								type="text"
								value={product.item_code}
								style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: var(--radius-sm);"
							/>
						</div>
						<div>
							<label
								class="text-uppercase opacity-50"
								style="font-size: 0.65rem; display: block; margin-bottom: 0.5rem; font-weight: 600;"
								>Harga (Rp)</label
							>
							<input
								type="text"
								class="currency-mask"
								data-hidden-id="product_price_input"
								required
								id="product_price_input_display"
								value={product.price}
								style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: var(--radius-sm);"
							/>
							<input type="hidden" name="price" id="product_price_input" value={product.price} />
							<div
								id="price_markup_preview"
								style="font-size: 0.65rem; color: #10b981; margin-top: 0.4rem; font-weight: 600; display: ${product.original_price ? 'block' : 'none'};"
							>
								Harga Coret: Rp <span id="markup_val"
									>{
										product.original_price
											? Number(
													product.original_price,
												).toLocaleString("id-ID")
											: "0"
									}</span
								> (Hemat Rp <span id="markup_pct">{product.original_price ? Number(product.original_price - product.price).toLocaleString("id-ID") : "0"}</span>)
							</div>
							<input
								type="hidden"
								name="original_price"
								id="original_price_input"
								value={product.original_price || ""}
							/>
						</div>
					</div>

					<div
						style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-lg);"
					>
						<div class="filter-group">
							<div id="category-chain-container" style="display:none;"></div>
							<label
								class="text-uppercase opacity-50"
								style="font-size: 0.65rem; display: block; margin-bottom: 0.5rem; font-weight: 600;"
								>Kategori Produk</label
							>
							<div
								class="searchable-select"
								data-ss-type="product-l1"
							>
								<input
									type="hidden"
									name="category_ids"
									id="l1_category_input"
									value={currentL1CatId}
								/>
								<input
									type="text"
									class="ss-input"
									placeholder="Cari & Pilih Kategori Utama..."
									readonly
									value={types.find(
										(t) => t.id === currentL1CatId,
									)?.name || ""}
									style="background: #ffffff; border-style: solid;"
								/>
								<div class="ss-dropdown">
									<div class="ss-search-container">
										<svg
											class="ss-search-icon"
											width="14"
											height="14"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2.5"
											><circle cx="11" cy="11" r="8"
											></circle><path
												d="M21 21l-4.35-4.35"
											></path></svg
										>
										<input
											type="text"
											class="ss-search"
											placeholder="Cari kategori..."
										/>
									</div>
									<div class="ss-options">
										{
											hierarchicalTypes
												.filter(
													(t) => t.parent_id === null,
												)
												.map((t) => (
													<div
														class="ss-option"
														data-value={t.id}
													>
														<span>{t.name}</span>
														<span class="lvl-badge lvl-1">
															Root
														</span>
													</div>
												))
										}
									</div>
								</div>
							</div>

							<div
								id="sub-category-checkboxes"
								class="cascading-container"
							>
							</div>
						</div>
						<div>
							<label
								class="text-uppercase opacity-50"
								style="font-size: 0.65rem; display: block; margin-bottom: 0.5rem; font-weight: 600;"
								>Status Katalog</label
							>
							<label
								style="display: flex; align-items: center; gap: 0.5rem; padding: 0.8rem; border: 1px solid #ddd; border-radius: var(--radius-sm); cursor: pointer; background: #fcfcfc;"
							>
								<input
									type="checkbox"
									name="is_active"
									checked={product.is_active}
								/>
								<span style="font-size: 0.85rem;"
									>Tampilkan di Toko (In Stock)</span
								>
							</label>
						</div>
					</div>

					<div>
						<label
							class="text-uppercase opacity-50"
							style="font-size: 0.65rem; display: block; margin-bottom: 0.5rem; font-weight: 600;"
							>Motif Batik (Bisa Pilih Banyak)</label
						>
						<div class="motif-style-container" id="motif-grid">
							{
								motifs?.map((m) => (
									<label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; cursor: pointer;">
										<input
											type="checkbox"
											name="motif_ids"
											value={m.id}
											checked={selectedMotifIds.includes(
												m.id,
											)}
										/>
										{m.name}
									</label>
								))
							}
						</div>
						<div class="custom-entry-row" style="margin-top: 8px; display: flex; gap: 8px;">
							<input type="text" id="new-motif-input" placeholder="Tambah Motif Baru..." style="flex: 1; font-size: 0.75rem; padding: 6px 10px; border: 1px dashed #ccc; border-radius: 6px;" />
							<button type="button" id="add-motif-btn" style="font-size: 0.7rem; background: #0f172a; color: #fff; border: none; padding: 0 12px; border-radius: 6px; cursor: pointer; font-weight: 600;">+ BUAT</button>
						</div>
					</div>

					<div>
						<label
							class="text-uppercase opacity-50"
							style="font-size: 0.65rem; display: block; margin-bottom: 0.5rem; font-weight: 600;"
							>Warna Utama (Multi-select)</label
						>
						<div class="motif-style-container" id="color-grid">
							{
								colorsData?.map((c) => (
									<label class="motif-style-label" style="gap: 0.5rem !important; align-items: center;">
										<input
											type="checkbox"
											name="colors"
											value={c.name}
											checked={selectedColors.includes(c.name)}
										/>
										<span style={`display:inline-block; width:12px; height:12px; border-radius:50%; background-color:${c.hex || '#cccccc'}; border: 1px solid rgba(0,0,0,0.15); flex-shrink:0;`}></span>
										{c.name}
									</label>
								))
							}
							{
								/* Persistent Custom Render: Display colors that are associated but NOT in colorsData */
								selectedColors.filter(sc => !colorsData.some(ac => ac.name === sc)).map((sc) => (
									<label class="motif-style-label" style="gap: 0.5rem !important; align-items: center; border: 1px dashed #94a3b8;">
										<input
											type="checkbox"
											name="colors"
											value={sc}
											checked={true}
										/>
										<span style={`display:inline-block; width:12px; height:12px; border-radius:50%; background-color:#cccccc; border: 1px solid rgba(0,0,0,0.15); flex-shrink:0;`}></span>
										{sc}
									</label>
								))
							}
						</div>
						<div class="custom-entry-row" style="margin-top: 8px; display: flex; gap: 8px;">
							<input type="text" id="new-color-input" placeholder="Tambah Warna Kustom..." style="flex: 1; font-size: 0.75rem; padding: 6px 10px; border: 1px dashed #ccc; border-radius: 6px;" />
							<button type="button" id="add-color-btn" style="font-size: 0.7rem; background: #0f172a; color: #fff; border: none; padding: 0 12px; border-radius: 6px; cursor: pointer; font-weight: 600;">+ BUAT</button>
						</div>
					</div>

					<div>
							<label
								class="text-uppercase opacity-50"
								style="font-size: 0.65rem; display: block; margin-bottom: 0.5rem; font-weight: 600;"
								>Ukuran & Variasi Harga</label
							>
							<p style="font-size: 0.7rem; color: var(--color-muted); margin-bottom: 1rem;">Centang ukuran yang tersedia, lalu isi harga khususnya jika berbeda.</p>

							{(() => {
								const sleeveKeywords = ['kemeja', 'baju', 'hem', 'atasan', 'blouse', 'tunik', 'gamis', 'koko', 'pdh', 'jaket'];
								const categoryNames = (product.categories || product.product_categories || []).map((pc:any) => (pc.name || pc.types?.name || '').toLowerCase()) || [];
								if (product.types?.name) categoryNames.push(product.types?.name?.toLowerCase());
								const jenisStr = categoryNames.join(" ");
								const needsSleeve = sleeveKeywords.some(kw => jenisStr.includes(kw));
								
								const hasLengan = (product.variants || product.product_variants || [])?.some((v:any) => v.size_name?.includes('Lengan Pendek') || v.size_name?.includes('Lengan Panjang'));
								
								const showWrapper = hasLengan || needsSleeve;

								return (
									<label id="sleeve_toggle_wrapper" style={`display: ${showWrapper ? 'flex' : 'none'}; align-items: center; gap: 0.5rem; padding: 0.8rem; border: 1px solid #ddd; border-radius: var(--radius-sm); cursor: pointer; background: #fcfcfc; margin-bottom: 1rem;`}>
										<input type="checkbox" id="toggle_sleeve_options" checked={hasLengan} />
										<span style="font-size: 0.85rem; font-weight: 500;">Aktifkan Pilihan Lengan (Pendek & Panjang)</span>
									</label>
								);
							})()}

							<div
								style="display: flex; flex-direction: column; gap: 0.5rem; background: #fcfcfc; padding: 1rem; border: 1px solid #ddd; border-radius: var(--radius-sm);"
							>
								{
									sizesData.map((s) => {
										const hasLengan = (product.variants || product.product_variants || [])?.some((v:any) => v.size_name?.includes('Lengan Pendek') || v.size_name?.includes('Lengan Panjang'));
										// Standard size mapping
										const existingVarStd = (product.variants || product.product_variants || [])?.find((v:any) => v.size_name === s.name);
										const isCheckedStd = !!existingVarStd;
										const vPriceStd = isCheckedStd ? existingVarStd.price : product.price;
										const vStockStd = isCheckedStd ? existingVarStd.stock : 0;
										const vDalamanStd = isCheckedStd ? existingVarStd.dalaman || "" : "";

										// Lengan split mapping
										const vPendek = `${s.name} - Lengan Pendek`;
										const existingVarPendek = (product.variants || product.product_variants || [])?.find((v:any) => v.size_name === vPendek);
										const isCheckedPendek = !!existingVarPendek;
										const vPricePendek = isCheckedPendek ? existingVarPendek.price : product.price;
										const vStockPendek = isCheckedPendek ? existingVarPendek.stock : 0;
										const vDalamanPendek = isCheckedPendek ? existingVarPendek.dalaman || "" : "";

										const vPanjang = `${s.name} - Lengan Panjang`;
										const existingVarPanjang = (product.variants || product.product_variants || [])?.find((v:any) => v.size_name === vPanjang);
										const isCheckedPanjang = !!existingVarPanjang;
										const vPricePanjang = isCheckedPanjang ? existingVarPanjang.price : product.price;
										const vStockPanjang = isCheckedPanjang ? existingVarPanjang.stock : 0;
										const vDalamanPanjang = isCheckedPanjang ? existingVarPanjang.dalaman || "" : "";

										return (
										<>
										<div class="variant-item variant-standard" style={`display: ${hasLengan ? 'none' : 'flex'}; align-items: center; gap: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #eee;`}>
											<label style="display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.85rem; cursor: pointer; min-width: 60px;">
												<input type="checkbox" class="variant-cb" value={s.name} checked={isCheckedStd} style="margin-top: 2px;" />
												<span style="display: flex; flex-direction: column;">
													<strong style="font-weight: 500;">{s.name}</strong>
												</span>
											</label>
											<input type="hidden" name="variant_size" value={s.name} disabled={!isCheckedStd} class="v-size-input" />
											<div class="v-details" style={`flex: 1; gap: 0.5rem; display: ${isCheckedStd ? 'flex' : 'none'};`}>
												<div style="flex: 1;">
													<span style="font-size: 0.6rem; opacity: 0.5;">Harga (Rp)</span>
													<input type="text" value={vPriceStd} placeholder="Harga" style="width: 100%; padding: 0.4rem; border: 1px solid #ccc; font-size: 0.8rem; border-radius: 4px;" disabled={!isCheckedStd} class="v-price-input currency-mask" />
													<input type="hidden" name="variant_price" value={vPriceStd} disabled={!isCheckedStd} class="v-price-hidden-input" />
												</div>
												<div style="width: 80px;">
													<span style="font-size: 0.6rem; opacity: 0.5;">Stok</span>
													<input type="number" name="variant_stock" value={vStockStd} placeholder="Stok" style="width: 100%; padding: 0.4rem; border: 1px solid #ccc; font-size: 0.8rem; border-radius: 4px;" disabled={!isCheckedStd} class="v-stock-input" />
												</div>
												<div style="width: 120px;">
													<span style="font-size: 0.6rem; opacity: 0.5;">Dalaman</span>
													<select name="variant_dalaman" disabled={!isCheckedStd} class="v-dalaman-input" style="width: 100%; padding: 0.4rem; border: 1px solid #ccc; font-size: 0.8rem; border-radius: 4px; background: white url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23777%22 stroke-width=%222.5%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22><path d=%22m6 9 6 6 6-6%22/></svg>') no-repeat right 0.6rem center; background-size: 10px; padding-right: 1.5rem; appearance: none; -webkit-appearance: none; -moz-appearance: none; cursor: pointer;">
														<option value="" selected={vDalamanStd === ""}>Tanpa Dalaman</option>
														<option value="F" selected={vDalamanStd === "F"}>Furing (F)</option>
														<option value="TF" selected={vDalamanStd === "TF"}>Tanpa Furing (TF)</option>
													</select>
												</div>
											</div>
										</div>

