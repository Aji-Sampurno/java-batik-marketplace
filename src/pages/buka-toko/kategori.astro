---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { apiFetch } from "../../lib/api";

// Check for session (Authentication Gate)
const session = Astro.cookies.get("admin_session");
if (session?.value !== "authenticated") {
	return Astro.redirect("/login");
}
const publicApiUrl = import.meta.env.PUBLIC_API_URL || "https://api.katalog.batik.gooproper.id/api";

let settings: any = { site_name: "Batik Nusantara" };
let message = "";
let isError = false;

try {
	const sRes = await apiFetch<any>("settings");
	settings = sRes?.data || sRes || { site_name: "Batik Nusantara" };
} catch (e: any) {
	console.error("Settings fetch error:", e.message);
}

// Recursive logic and API block has been lifted to asynchronous client-side JS.

// Handle Form Submission (Server Side)
if (Astro.request.method === "POST") {
	try {
		const formData = await Astro.request.formData();
		const action = formData.get("action");

		if (action === "add_type") {
			const name = formData.get("name");
			const parent_id = formData.get("parent_id") || null;
			let category_level = 1;

			if (parent_id) {
				const parent = await apiFetch<any>(`types/${parent_id}`);
				const parentData = parent?.data || parent;
				if (parentData) {
					category_level = Number(parentData.category_level || 1) + 1;
				}
			}

			if (category_level > 3) {
				throw new Error("Maksimal hirarki kategori adalah 3 level.");
			}

			await apiFetch("types", {
				method: "POST",
				body: JSON.stringify({ name, parent_id, category_level }),
			});
			return Astro.redirect("/buka-toko/kategori?success=type");
		}

		if (action === "delete_type") {
			const id = formData.get("id");
			await apiFetch(`types/${id}`, { method: "DELETE" });
			return Astro.redirect("/buka-toko/kategori?success=deleted");
		}
	} catch (e: any) {
		isError = true;
		return Astro.redirect(`/buka-toko/kategori?error=${encodeURIComponent(e.message || "Gagal memproses tindakan")}`);
	}
}

const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
if (success === "type") message = "Kategori baru berhasil ditambahkan!";
if (success === "deleted") message = "Kategori berhasil dihapus!";
---

<Layout title={`Kelola Kategori - ${settings?.site_name || "Batik Nusantara"}`}>
	<section style="padding: 130px 0 var(--spacing-2xl) 0; background: #fdfcfb; min-height: 100vh;">
		<div class="container" style="max-width: 1000px;">
			<!-- Header -->
			<div style="margin-bottom: var(--spacing-xl);">
				<h1 style="font-family: var(--font-serif); font-size: 2.2rem; margin: 0; font-weight: 400;">
					Manajemen <span style="font-style: italic;">Kategori</span>
				</h1>
				<p style="opacity: 0.5; margin-top: 0.5rem; font-size: 0.9rem;">
					Kelola struktur hirarki kategori batik hingga 3 level.
				</p>
			</div>

			<!-- Flash Message -->
			{
				message && (
					<div
						style="background: #e6f9e9; color: #0d5a15; padding: 1rem 1.5rem; border-radius: 8px; margin-bottom: 2rem; display: flex; align-items: center; gap: 10px; font-size: 0.9rem; border: 1px solid rgba(13, 90, 21, 0.1);"
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
						{message}
					</div>
				)
			}

			<!-- Error Message -->
			{
				error && (
					<div
						style="background: #fff5f5; color: #b91c1c; padding: 1rem 1.5rem; border-radius: 8px; margin-bottom: 2rem; display: flex; align-items: center; gap: 10px; font-size: 0.9rem; border: 1px solid rgba(185, 28, 28, 0.1);"
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 8v4M12 16h.01"/></svg>
						<strong>Error:</strong> {error}
					</div>
				)
			}

			<div style="display: grid; grid-template-columns: 1fr; gap: var(--spacing-lg);">
				<div style="background: white; border: 1px solid var(--color-border); padding: 2.5rem; border-radius: var(--radius-md); box-shadow: var(--shadow-sm);">
					<h3 style="font-size: 0.85rem; margin-bottom: 1.5rem; font-weight: 700; letter-spacing: 1px;" class="text-uppercase">
						Tambah Kategori Baru
					</h3>
					
					<form
						method="POST"
						style="display: flex; flex-direction: column; gap: 1.2rem; margin-bottom: 2.5rem;"
					>
						<input
							type="hidden"
							name="action"
							value="add_type"
						/>
						
						<div>
							<label class="input-label">Pilih Induk Kategori (Opsional)</label>
							<div class="searchable-select" data-ss-type="parent">
								<input
									type="hidden"
									name="parent_id"
									id="parent_id_input"
								/>
								<input
									type="text"
									class="ss-input"
									placeholder="Kategori Utama (Root)..."
									readonly
									style="background: #fdfcfb; border: 1px solid #ddd; width: 100%; padding: 0.8rem; border-radius: 8px; font-size: 0.9rem; cursor: pointer;"
								/>
								<div class="ss-dropdown">
									<div class="ss-search-container">
										<svg class="ss-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.35-4.35"></path></svg>
										<input
											type="text"
											class="ss-search"
											placeholder="Cari induk kategori..."
										/>
									</div>
									<div class="ss-options" id="dropdown-options-container">
										<div class="ss-option" data-value="">
											<span>Kategori Utama (Root)...</span>
											<span class="lvl-badge lvl-1">Root</span>
										</div>
										<!-- Dynamic parent options will populate asynchronously -->
									</div>
								</div>
							</div>
						</div>

						<div>
							<label class="input-label">Nama Kategori</label>
							<div style="display: flex; gap: var(--spacing-sm);">
								<input
									name="name"
									type="text"
									required
									placeholder="Nama Kategori..."
									style="flex: 1; padding: 0.8rem; border: 1px solid #ddd; border-radius: 8px; font-size: 0.9rem;"
								/>
								<button
									type="submit"
									style="background: var(--color-text); color: white; padding: 0.8rem 1.5rem; border: none; font-size: 0.75rem; font-weight: 700; cursor: pointer; border-radius: 8px; text-transform: uppercase; letter-spacing: 1px; transition: 0.3s;"
									onmouseover="this.style.background='#000'"
									onmouseout="this.style.background='var(--color-text)'"
								>
									TAMBAH
								</button>
							</div>
						</div>
					</form>

					<div style="border-top: 1px solid #f3f4f6; padding-top: 2rem;">
						<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
							<p class="text-uppercase opacity-50" style="font-size: 0.7rem; font-weight: 700; letter-spacing: 1.5px;">
								Daftar Kategori Terdaftar
							</p>
							<span style="font-size: 0.75rem; color: #9ca3af; font-weight: 600;" id="category-count-text">
								-- Kategori
							</span>
						</div>

						<div class="category-tree-wrapper" id="category-tree-container">
							<!-- High-performance visual skeleton placeholder -->
							<div style="padding: 4rem; text-align: center; opacity: 0.6;">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation: spin 1.2s linear infinite; margin: 0 auto 1rem auto; display: block;"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
								<p style="font-size: 0.8rem; font-weight: 500;">Memuat struktur kategori...</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Custom Delete Modal -->
	<div id="delete-modal" class="modal-overlay">
		<div class="modal-content">
			<div class="modal-header">
				<div class="warning-icon">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01"/></svg>
				</div>
				<h3 style="font-family: var(--font-serif); font-size: 1.5rem; font-weight: 400; margin: 0;">Konfirmasi <span style="font-style: italic;">Hapus</span></h3>
			</div>
			<p style="opacity: 0.6; line-height: 1.6; margin: 1.5rem 0; font-size: 0.95rem;">Apakah Anda yakin ingin menghapus kategori ini? Pastikan tidak ada sub-kategori atau produk yang menggunakannya.</p>
			<div class="modal-footer">
				<button type="button" id="cancel-btn" class="btn-admin-secondary">Batal</button>
				<button type="button" id="confirm-btn" class="btn-admin-danger">Ya, Hapus</button>
			</div>
		</div>
	</div>

	<script is:inline define:vars={{ publicApiUrl }}>
		// Ultra-efficient recursive JSON flattener (Handles pre-built API relational trees)
		function flattenCategoryTree(nestedList, depth = 0) {
			let result = [];
			if (!Array.isArray(nestedList)) return result;
			nestedList.forEach(item => {
				result.push({ ...item, depth });
				if (item.children && item.children.length > 0) {
					const childList = flattenCategoryTree(item.children, depth + 1);
					result = result.concat(childList);
				}
			});
			return result;
		}

		// Main Hydration Sequence
		async function fetchAndHydrateCategories() {
			const treeContainer = document.getElementById('category-tree-container');
			const dropdownContainer = document.getElementById('dropdown-options-container');
			const countText = document.getElementById('category-count-text');

			try {
				const res = await fetch(`${publicApiUrl}/types`);
				const json = await res.json();
				const list = json.data || json || [];
				
				const tree = flattenCategoryTree(list);
				
				// 1. Inject Dropdown parent options (Only depth 0 and 1)
				const dropdownHtml = tree.filter(t => t.depth < 2).map(t => `
					<div class="ss-option" data-value="${t.id}">
						<span>${"--".repeat(t.depth)} ${t.name}</span>
						<span class="lvl-badge lvl-${t.depth + 1}">L${t.depth + 1}</span>
					</div>
				`).join('');
				
				if (dropdownContainer) {
					dropdownContainer.innerHTML = `
						<div class="ss-option" data-value="">
							<span>Kategori Utama (Root)</span>
							<span class="lvl-badge lvl-1">Root</span>
						</div>
						${dropdownHtml}
					`;
				}

				// 2. Inject Tree Node Items
				if (treeContainer) {
					if (tree.length === 0) {
						treeContainer.innerHTML = `
							<div style="padding: 4rem; text-align: center; border: 1px dashed #e5e7eb; border-radius: 12px;">
								<p style="font-size: 0.9rem; color: #9ca3af; opacity: 0.6;">Belum ada struktur kategori.</p>
							</div>
						`;
					} else {
						treeContainer.innerHTML = tree.map(t => `
							<div class="category-item" style="margin-left: ${t.depth * 28}px; border-color: ${t.depth === 0 ? '#f3f4f6' : 'transparent'};">
								${t.depth > 0 ? '<div class="tree-connector"></div>' : ''}
								<div class="cat-content">
									<span class="lvl-badge lvl-${t.depth + 1}">L${t.depth + 1}</span>
									<span class="cat-name" style="font-weight: ${t.depth === 0 ? '600' : '400'}; color: ${t.depth === 0 ? '#111827' : '#4b5563'};">${t.name}</span>
								</div>
								<div class="cat-actions">
									<form method="POST" class="delete-form">
										<input type="hidden" name="action" value="delete_type" />
										<input type="hidden" name="id" value="${t.id}" />
										<button type="button" class="btn-trash" title="Hapus Kategori" onclick="openDeleteModal(this.form)">
											<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg>
										</button>
									</form>
								</div>
							</div>
						`).join('');
					}
				}

				// 3. Update counters
				if (countText) {
					countText.innerText = `${tree.length} Kategori`;
				}

				// 4. Setup searchable selections AFTER nodes exist in DOM
				initSearchableSelect();

			} catch (err) {
				console.error('[Category Hydration Fail]:', err);
				if (treeContainer) {
					treeContainer.innerHTML = `<p style="color: #b91c1c; font-weight: 600; text-align: center; padding: 2rem;">Koneksi API gagal.</p>`;
				}
			}
		}

		// Searchable dropdown logic
		function initSearchableSelect() {
			const selectContainers = document.querySelectorAll(".searchable-select");

			selectContainers.forEach((container) => {
				const input = container.querySelector(".ss-input");
				const hiddenInput = container.querySelector('input[type="hidden"]');
				const dropdown = container.querySelector(".ss-dropdown");
				const searchInput = container.querySelector(".ss-search");
				const options = container.querySelectorAll(".ss-option");

				input.addEventListener("click", (e) => {
					e.stopPropagation();
					dropdown.classList.toggle("show");
					if (dropdown.classList.contains("show")) {
						searchInput.focus();
					}
				});

				searchInput.addEventListener("input", (e) => {
					const term = e.target.value.toLowerCase();
					options.forEach((opt) => {
						const text = opt.textContent.toLowerCase();
						opt.style.display = text.includes(term) ? "flex" : "none";
					});
				});

				options.forEach((opt) => {
					opt.addEventListener("click", (e) => {
						e.stopPropagation();
						const val = opt.getAttribute("data-value");
						const text = opt.querySelector("span").textContent.trim();

						hiddenInput.value = val;
						input.value = text;
						dropdown.classList.remove("show");
					});
				});

				document.addEventListener("click", () => {
					dropdown.classList.remove("show");
				});
			});
		}

		// Delete Confirmation Modal
		let currentForm = null;
		const modal = document.getElementById('delete-modal');
		const confirmBtn = document.getElementById('confirm-btn');
		const cancelBtn = document.getElementById('cancel-btn');

		window.openDeleteModal = function(form) {
			currentForm = form;
			modal.classList.add('active');
			document.body.style.overflow = 'hidden';
		}

		function closeModal() {
			modal.classList.remove('active');
			document.body.style.overflow = '';
			currentForm = null;
		}

		cancelBtn.addEventListener('click', closeModal);
		
		confirmBtn.addEventListener('click', () => {
			if (currentForm) {
				confirmBtn.disabled = true;
				confirmBtn.innerText = "Menghapus...";
				currentForm.submit();
			}
		});

		modal.addEventListener('click', (e) => {
			if (e.target === modal) closeModal();
		});

		document.addEventListener("DOMContentLoaded", () => {
			fetchAndHydrateCategories();
		});
	</script>

	<style is:global>
		.input-label {
			font-size: 0.65rem;
			text-transform: uppercase;
			letter-spacing: 1.5px;
			opacity: 0.5;
			font-weight: 700;
			display: block;
			margin-bottom: 0.5rem;
		}

		/* Searchable dropdown styles */
		.searchable-select {
			position: relative;
			width: 100%;
		}
		.ss-dropdown {
			position: absolute;
			top: 100%;
			left: 0;
			width: 100%;
			background: white;
			border: 1px solid #e5e7eb;
			border-radius: 8px;
			box-shadow: 0 10px 30px rgba(0,0,0,0.08);
			z-index: 100;
			margin-top: 5px;
			display: none;
			max-height: 250px;
			overflow-y: auto;
		}
		.ss-dropdown.show {
			display: block;
		}
		.ss-search-container {
			display: flex;
			align-items: center;
			padding: 0.8rem;
			border-bottom: 1px solid #f3f4f6;
			gap: 8px;
			position: sticky;
			top: 0;
			background: white;
		}
		.ss-search {
			width: 100%;
			border: none;
			outline: none;
			font-size: 0.85rem;
		}
		.ss-search-icon {
			color: #9ca3af;
		}
		.ss-option {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 0.8rem;
			cursor: pointer;
			font-size: 0.85rem;
			transition: background 0.2s;
		}
		.ss-option:hover {
			background: #fdfcfb;
			color: var(--color-accent);
		}

		/* Hierarchy list styles */
		.category-tree-wrapper {
			display: flex;
			flex-direction: column;
			gap: var(--spacing-xs);
		}
		.category-item {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 0.75rem 1rem;
			background: #fdfdfd;
			border-radius: 8px;
			border: 1px solid #f1f1f1;
			position: relative;
			transition: 0.2s;
		}
		.category-item:hover {
			background: #fbfbfb;
			border-color: #e5e7eb;
		}
		.tree-connector {
			position: absolute;
			left: -18px;
			top: -12px;
			width: 15px;
			height: 28px;
			border-left: 2px dashed #e5e7eb;
			border-bottom: 2px dashed #e5e7eb;
			border-bottom-left-radius: 4px;
			pointer-events: none;
		}
		.cat-content {
			display: flex;
			align-items: center;
			gap: 10px;
		}
		.cat-name {
			font-size: 0.85rem;
		}
		.lvl-badge {
			padding: 3px 8px;
			border-radius: 4px;
			font-size: 0.55rem;
			font-weight: 800;
			letter-spacing: 0.5px;
		}
		.lvl-1 { background: #fffbeb; color: #b45309; }
		.lvl-2 { background: #eff6ff; color: #1d4ed8; }
		.lvl-3 { background: #f0fdf4; color: #15803d; }

		.btn-trash {
			background: none;
			border: none;
			color: #ff4d4d;
			cursor: pointer;
			opacity: 0.5;
			padding: 4px;
			display: flex;
			align-items: center;
			transition: 0.2s;
			border-radius: 4px;
		}
		.btn-trash:hover {
			opacity: 1;
			background: #fff5f5;
			transform: scale(1.1);
		}

		/* Modal Styles */
		.modal-overlay {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: rgba(0, 0, 0, 0.4);
			backdrop-filter: blur(4px);
			display: flex;
			align-items: center;
			justify-content: center;
			z-index: 9999;
			opacity: 0;
			visibility: hidden;
			transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		}
		.modal-overlay.active {
			opacity: 1;
			visibility: visible;
		}
		.modal-content {
			background: white;
			width: 100%;
			max-width: 400px;
			padding: 2.5rem;
			border-radius: 16px;
			box-shadow: 0 20px 50px rgba(0,0,0,0.15);
			transform: translateY(20px);
			transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		}
		.modal-overlay.active .modal-content {
			transform: translateY(0);
		}
		.modal-header {
			display: flex;
			align-items: center;
			gap: 15px;
			margin-bottom: 1rem;
		}
		.warning-icon {
			width: 40px;
			height: 40px;
			background: #fff5f5;
			color: #b91c1c;
			border-radius: 12px;
			display: flex;
			align-items: center;
			justify-content: center;
		}
		.modal-footer {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 12px;
			margin-top: 0.5rem;
		}
		.btn-admin-secondary {
			padding: 0.8rem;
			border-radius: 8px;
			font-size: 0.75rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 1px;
			cursor: pointer;
			background: #f5f5f5;
			border: 1px solid #eee;
			color: #666;
			transition: all 0.2s;
		}
		.btn-admin-secondary:hover {
			background: #eee;
		}
		.btn-admin-danger {
			padding: 0.8rem;
			border-radius: 8px;
			font-size: 0.75rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 1px;
			cursor: pointer;
			background: #b91c1c;
			border: none;
			color: white;
			transition: all 0.2s;
		}
		.btn-admin-danger:hover {
			background: #991b1b;
			box-shadow: 0 4px 12px rgba(185, 28, 28, 0.2);
		}
	</style>
</Layout>
