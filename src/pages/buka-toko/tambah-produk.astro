							const imgPreview = document.getElementById("praproduk_img_preview");
							const layoutContainer = document.getElementById("praproduk_layout_container");

							if (photoFile && imgPreview && imgWrapper) {
								imgPreview.dataset.filename = photoFile;
								imgPreview.src = BASE_PHOTO_URL + photoFile;
