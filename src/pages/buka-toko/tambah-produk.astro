			gap: 0.75rem !important;
			font-size: 0.85rem !important;
			cursor: pointer !important;
			margin: 0 !important;
			padding: 0.4rem 0.6rem !important;
			color: #334155 !important;
			border-radius: 6px !important;
			transition:
				background 0.2s,
				color 0.2s !important;
			white-space: normal !important;
			line-height: 1.3 !important;
			width: auto !important;
		}

		.motif-style-label:hover {
			background: #f1f5f9 !important;
			color: #0f172a !important;
		}

		.motif-style-label input {
			width: 16px !important;
			height: 16px !important;
			margin: 0 !important;
			cursor: pointer !important;
			accent-color: var(--color-accent) !important;
		}

		.l3-divider-premium {
			margin: 2rem 0 1rem 0 !important;
			border-top: 1px dashed #e2e8f0 !important;
			position: relative !important;
		}

		/* Step Label */
		.step-label {
			font-size: 0.65rem !important;
			color: #64748b !important;
			display: block !important;
			margin-bottom: 0.6rem !important;
			letter-spacing: 0.5px !important;
			text-transform: uppercase !important;
			opacity: 0.8 !important;
		}
	</style>
	<DeleteConfirmModal />

	<script is:inline define:vars={{ hierarchicalTypes }}>
		const BASE_PHOTO_URL = "https://noir.grace.gracianna.web.id/foto/";
		const BASE_PHOTO_URL_FALLBACK = "https://noir.grace.gracianna.web.id/storage/";
		const BASE_PHOTO_URL_IMAGES = "https://noir.grace.gracianna.web.id/images/";

		function handlePraprodukImageError(imgEl) {
			if (!imgEl.dataset.tried) {
				imgEl.dataset.tried = "1";
				imgEl.src = BASE_PHOTO_URL_FALLBACK + imgEl.dataset.filename;
			} else if (imgEl.dataset.tried === "1") {
				imgEl.dataset.tried = "2";
				imgEl.src = BASE_PHOTO_URL_IMAGES + imgEl.dataset.filename;
			} else {
				imgEl.style.display = "none";
				if(imgEl.parentElement) {
					imgEl.parentElement.style.display = "flex";
					imgEl.parentElement.style.alignItems = "center";
					imgEl.parentElement.style.justifyContent = "center";
					imgEl.parentElement.innerHTML = '<span style="font-size:0.7rem; color:#888;">Tidak ada foto</span>';
				}
			}
		}

		function initSearchableSelect() {
			const selectContainers =
				document.querySelectorAll(".searchable-select");

			selectContainers.forEach((container) => {
				const input = container.querySelector(".ss-input");
				const hiddenInput = container.querySelector(
					'input[type="hidden"]',
				);
				const dropdown = container.querySelector(".ss-dropdown");
				const searchInput = container.querySelector(".ss-search");
				const options = container.querySelectorAll(".ss-option");
				const optionsContainer = container.querySelector(".ss-options");
				const ssType = container.getAttribute("data-ss-type");

				// Open/Close
				input.addEventListener("click", (e) => {
					e.stopPropagation();
					dropdown.classList.toggle("show");
					if (dropdown.classList.contains("show")) {
						searchInput.focus();
					}
				});

				// Search Logic
				searchInput.addEventListener("input", (e) => {
					const term = e.target.value.toLowerCase();
					let hasResults = false;

					options.forEach((opt) => {
						const text = opt.textContent.toLowerCase();
						if (text.includes(term)) {
							opt.style.display = "block";
							hasResults = true;
						} else {
							opt.style.display = "none";
						}
					});

					// Handle Custom Dynamic Entry injection
					let customOpt = optionsContainer.querySelector(".ss-custom-add");
					if (term.length > 0) {
						if (!customOpt) {
							customOpt = document.createElement("div");
							customOpt.className = "ss-option ss-custom-add";
							customOpt.style.cssText = "background:#f8fafc; color:#2563eb; font-weight:600; border-top:1px dashed #cbd5e1; display: flex; justify-content: space-between; align-items: center;";
							optionsContainer.appendChild(customOpt);
							customOpt.addEventListener("click", (e) => {
								e.stopPropagation();
								const rawVal = customOpt.getAttribute("data-raw");
								hiddenInput.value = rawVal;
								input.value = rawVal;
								dropdown.classList.remove("show");
								searchInput.value = "";
								
								options.forEach((o) => (o.style.display = "block"));
								options.forEach((o) => o.classList.remove("selected"));
								
								if (ssType === "product-l1") {
									categoryModeL1 = "custom"; // Toggle state to allow waterfall logic to accept custom
									renderSubCategoriesFromList(["_CUSTOM_L1_"]);
								}
								updateName();
							});
						}
						customOpt.innerHTML = `<span>➕ Pakai "${e.target.value}"...</span><span class="lvl-badge" style="background:#dbeafe;color:#1e40af;font-size:0.55rem;padding:2px 5px;border-radius:4px;font-weight:bold;text-transform:uppercase;">BARU</span>`;
						customOpt.setAttribute("data-raw", e.target.value);
						customOpt.style.display = "flex";
					} else if (customOpt) {
						customOpt.style.display = "none";
					}

					// Existing Handle "No results" fallback UI
					const noRes = optionsContainer.querySelector(".ss-no-results");
					if (!hasResults && term.length === 0) {
						if (!noRes) {
							const div = document.createElement("div");
							div.className = "ss-no-results";
							div.textContent = "Kategori tidak ditemukan";
							optionsContainer.appendChild(div);
						}
					} else if (noRes) {
						noRes.remove();
					}
				});

				// Selection
				options.forEach((opt) => {
					opt.addEventListener("click", (e) => {
						e.stopPropagation();
						const val = opt.getAttribute("data-value");
						const text =
							opt.querySelector("span")?.textContent.trim() ||
							opt.textContent.trim();

						hiddenInput.value = val;
						input.value = text;

						options.forEach((o) => o.classList.remove("selected"));
						opt.classList.add("selected");

						dropdown.classList.remove("show");
						searchInput.value = "";
						options.forEach((o) => (o.style.display = "block"));

						// HYBRID CALLBACK: If this is Product Level 1, render checkboxes
						if (ssType === "product-l1") {
							categoryModeL1 = "standard"; // Reset back to standard mode state so filtering works!
							renderSubCategoriesFromList([val]);
						}
					});
				});

				// Close when clicking outside
				document.addEventListener("click", (e) => {
					if (!container.contains(e.target)) {
						dropdown.classList.remove("show");
					}
				});
			});
		}

		let categoryModeL1 = "standard"; // 'standard' or 'custom'
		let customL1Val = "";

		function renderSubCategoriesFromList(parentIds) {
			const container = document.getElementById("sub-category-checkboxes");
			if (!container) return;

			// Logic to force render if mode is custom or parents present
			const isCustomMode = categoryModeL1 === "custom";
			const hasExistingParents = parentIds && parentIds.length > 0 && parentIds[0] !== "";

			if (!isCustomMode && !hasExistingParents) {
				container.innerHTML = "";
				container.style.display = "none";
				return;
			}

			// Clear container & init layout
			container.innerHTML = `
				<div style="margin-top: 1rem;">
					<label class="text-uppercase opacity-50" style="font-size: 0.65rem; display: block; margin-bottom: 0.5rem; font-weight: 600;">Jenis Produk (Level 2)</label>
					<div class="motif-style-container" id="l2-selection-row"></div>
					<div class="custom-entry-row" style="margin-top: 8px; display: flex; gap: 8px;">
						<input type="text" id="new-l2-input" placeholder="Tambah Jenis L2 Baru..." style="flex: 1; font-size: 0.75rem; padding: 6px 10px; border: 1px dashed #ccc; border-radius: 6px;" />
						<button type="button" id="add-l2-btn" style="font-size: 0.7rem; background: #0f172a; color: #fff; border: none; padding: 0 12px; border-radius: 6px; cursor: pointer; font-weight: 600;">+ BUAT</button>
					</div>
				</div>
				<div id="l3-selection-area" style="display: none; margin-top: 1.5rem;">
					<label class="text-uppercase opacity-50" style="font-size: 0.65rem; display: block; margin-bottom: 0.5rem; font-weight: 600;">Pilihan Detail (Level 3)</label>
					<div class="motif-style-container" id="l3-grid"></div>
					<div class="custom-entry-row" style="margin-top: 8px; display: flex; gap: 8px;">
						<input type="text" id="new-l3-input" placeholder="Tambah Detail L3 Baru..." style="flex: 1; font-size: 0.75rem; padding: 6px 10px; border: 1px dashed #ccc; border-radius: 6px;" />
						<button type="button" id="add-l3-btn" style="font-size: 0.7rem; background: #0f172a; color: #fff; border: none; padding: 0 12px; border-radius: 6px; cursor: pointer; font-weight: 600;">+ BUAT</button>
					</div>
				</div>
			`;
			container.style.display = "block";

			const l2Row = container.querySelector("#l2-selection-row");
			const l3Area = container.querySelector("#l3-selection-area");
			const l3Grid = container.querySelector("#l3-grid");

			// --- Dynamic Checkbox Maker Helper ---
			function createCatCheckbox(name, id, isL2, parentId, isCustom = false) {
				const label = document.createElement("label");
				label.className = "motif-style-label";
				if (isCustom) label.style.border = "1px dashed #94a3b8";
				
				const cleanVal = isCustom ? name : id;
				label.innerHTML = `
					<input type="checkbox" name="category_ids" value="${cleanVal}" data-id="${id}" data-parent="${parentId}" data-name="${name}" ${isCustom ? 'data-custom="true" checked' : ''} />
					${name} ${isCustom ? '<span style="font-size:0.5rem; color:blue; margin-left:4px;">NEW</span>' : ''}
				`;
				
				const cb = label.querySelector("input");
				cb.addEventListener("change", (e) => {
					if (isL2 && cb.checked) {
						// L2 is usually single-select chain root
						l2Row.querySelectorAll("input:checked").forEach(o => { if(o !== cb) o.checked = false; });
					}
					if (isL2) updateL3Selection();
					updateName();
				});
				return label;
			}

			// --- Level 3 Sub-Rendering Logic ---
			function updateL3Selection() {
				const checkedL2s = Array.from(l2Row.querySelectorAll("input:checked"));
				l3Grid.innerHTML = ""; // Clear old values
				
				if (checkedL2s.length === 0) {
					l3Area.style.display = "none";
					updateName();
					return;
				}
				
				l3Area.style.display = "block";
				
				checkedL2s.forEach(l2 => {
					const l2Id = l2.getAttribute("data-id");
					const isCustomL2 = l2.dataset.custom === "true";
					
					// Only attempt searching existing if it's a legitimate numeric/uuid from DB
					if (!isCustomL2) {
						const dbL3s = hierarchicalTypes.filter(t => String(t.parent_id) === String(l2Id));
						dbL3s.forEach(c => {
							l3Grid.appendChild(createCatCheckbox(c.name, c.id, false, l2Id, false));
						});
					}
				});
				updateName();
			}

			// --- Populate Existing Level 2 children from DB ---
			if (!isCustomMode && hasExistingParents) {
				const l2Children = hierarchicalTypes.filter(t => parentIds.includes(t.parent_id));
				l2Children.forEach(c => {
					l2Row.appendChild(createCatCheckbox(c.name, c.id, true, c.parent_id, false));
				});
			}

			// --- Handle Dynamic Input for L2 and L3 ---
			const inpL2 = document.getElementById('new-l2-input');
			const btnL2 = document.getElementById('add-l2-btn');
			const handleL2Add = () => {
				const text = inpL2.value.trim();
				if (!text) return;
				// Auto check-off others since L2 is single selection
				l2Row.querySelectorAll("input:checked").forEach(o => o.checked = false);
				// Inject dynamic element with unique temp random ID so we can chain to it
				const rndId = "custom-l2-" + Math.random().toString(36).substr(2, 5);
				const el = createCatCheckbox(text, rndId, true, parentIds[0], true);
				l2Row.appendChild(el);
				inpL2.value = '';
				updateL3Selection(); // refresh the L3 area immediately
			};
			btnL2?.addEventListener('click', handleL2Add);
			inpL2?.addEventListener('keypress', (e) => { if(e.key==='Enter'){ e.preventDefault(); handleL2Add(); } });

			const inpL3 = document.getElementById('new-l3-input');
			const btnL3 = document.getElementById('add-l3-btn');
			const handleL3Add = () => {
				const text = inpL3.value.trim();
				if (!text) return;
				const activeL2 = l2Row.querySelector("input:checked");
				const parentId = activeL2 ? activeL2.getAttribute("data-id") : null;
				const rndId = "custom-l3-" + Math.random().toString(36).substr(2, 5);
				l3Grid.appendChild(createCatCheckbox(text, rndId, false, parentId, true));
				inpL3.value = '';
				updateName();
			};
			btnL3?.addEventListener('click', handleL3Add);
			inpL3?.addEventListener('keypress', (e) => { if(e.key==='Enter'){ e.preventDefault(); handleL3Add(); } });

			updateName(); // triggers first sweep
		}

		// --- Product Naming Automation Logic ---
		const nameInput = document.getElementById("product_name_input");
		const itemCodeInput = document.getElementById("product_item_code_input");
		const categoryContainer = document.getElementById("sub-category-checkboxes");

		function updateName() {
			if (!nameInput) return;

			// --- Build CATEGORY DATA MAP ---
			let l1TextStr = "";
			let l1ValToSubmit = "";
			const l2Container = document.getElementById("l2-selection-row");
			const l3Container = document.getElementById("l3-grid");

			// Get L1 context
			const standardL1 = document.getElementById("l1_category_input");
			const visibleL1 = document.querySelector('[data-ss-type="product-l1"] .ss-input');
			
			l1ValToSubmit = standardL1 ? standardL1.value.trim() : "";
			l1TextStr = visibleL1 ? visibleL1.value.trim() : "";

			// Smart-Auto detect Custom mode: if it has content that is not empty and not a standard 36-char UUID format
			const isL1Uuid = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(l1ValToSubmit);
			if (l1ValToSubmit && !isL1Uuid) {
				categoryModeL1 = "custom";
			}

			// Get L2 context
			let l2TextStr = "";
			let l2ValToSubmit = "";
			if (l2Container) {
				const checkedL2 = l2Container.querySelector("input:checked");
				if (checkedL2) {
					l2TextStr = checkedL2.parentElement.textContent.replace("NEW", "").trim();
					l2ValToSubmit = checkedL2.dataset.custom === "true" ? l2TextStr : checkedL2.getAttribute("data-id");
				}
			}

			// Get L3 context
			const l3Strings = [];
			const l3ValsToSubmit = [];
			if (l3Container) {
				const checkedL3s = Array.from(l3Container.querySelectorAll("input:checked"));
				checkedL3s.forEach(c => {
					const txt = c.parentElement.textContent.replace("NEW", "").trim();
					l3Strings.push(txt);
					l3ValsToSubmit.push(c.dataset.custom === "true" ? txt : c.getAttribute("data-id"));
				});
			}

			// --- AUTOMATIC TITLE BUILDING ---
			const selectedCategories = [];
			if (l1TextStr && l1TextStr.toLowerCase() !== "root") selectedCategories.push(l1TextStr);
			if (l2TextStr) selectedCategories.push(l2TextStr);
			l3Strings.forEach(s => { if(s) selectedCategories.push(s); });
			const jenis = selectedCategories.join(" ");

			// Get Motifs
			let motifStr = "";
			const motifGrid = document.getElementById("motif-grid");
			if (motifGrid) {
				const checkedMotifs = Array.from(motifGrid.querySelectorAll("input:checked"));
				motifStr = checkedMotifs.map((m) => m.parentElement.textContent.trim()).join(", ");
			}

			// Get Colors
			let colorStr = "";
			const colorGrid = document.getElementById("color-grid");
			if (colorGrid) {
				const checkedColors = Array.from(colorGrid.querySelectorAll("input:checked"));
				colorStr = checkedColors.map((c) => c.value).join(", ");
			}

			const itemCode = itemCodeInput?.value.trim() || "";
			const parts = [];
			if (jenis) parts.push(jenis);
			if (motifStr) parts.push(motifStr);
			if (colorStr) parts.push(colorStr);

			// Auto append "Tanpa Furing" for Kemeja if lining is TF (Tanpa Furing) or "" (Tanpa Dalaman)
			if (jenis && jenis.toLowerCase().includes("kemeja")) {
				const activeDalamans = Array.from(document.querySelectorAll('.v-dalaman-input-add:not(:disabled)'));
				const isTanpaFuring = activeDalamans.length > 0 && activeDalamans.some(select => select.value === 'TF' || select.value === '');
				if (isTanpaFuring) {
					parts.push("Tanpa Furing");
				}
			}

			if (itemCode) parts.push(itemCode);
			
			nameInput.value = parts.join(" ");

			// --- SERIALIZE CATEGORY CHAIN FOR SUBMIT ---
			// Constructs valid waterfall logic: Array chain of [L1Val, L2Val, L3Val]
			const chainBox = document.getElementById("category-chain-container");
			if (chainBox) {
				chainBox.innerHTML = "";
				if (l1ValToSubmit) {
					chainBox.innerHTML += `<input type="hidden" name="category_chain[]" value="${l1ValToSubmit}" />`;
					if (l2ValToSubmit) {
						chainBox.innerHTML += `<input type="hidden" name="category_chain[]" value="${l2ValToSubmit}" />`;
						// We'll push the FIRST L3 found as the leaf node waterfall
						if (l3ValsToSubmit.length > 0) {
							chainBox.innerHTML += `<input type="hidden" name="category_chain[]" value="${l3ValsToSubmit[0]}" />`;
						}
					}
				}
			}

			// --- Sleeve Toggle Visibility based on Category ---
			const sleeveKeywords = ['kemeja', 'baju', 'hem', 'atasan', 'blouse', 'tunik', 'gamis', 'koko', 'pdh', 'jaket'];
			const jenisLower = jenis.toLowerCase();
			const needsSleeve = sleeveKeywords.some(kw => jenisLower.includes(kw));
			const sleeveWrapper = document.getElementById('sleeve_toggle_wrapper');
			if (sleeveWrapper) {
				if (needsSleeve) {
					sleeveWrapper.style.display = 'flex';
				} else {
					sleeveWrapper.style.display = 'none';
					const toggleCb = document.getElementById('toggle_sleeve_options_add');
					if (toggleCb && toggleCb.checked) {
						toggleCb.checked = false;
						toggleCb.dispatchEvent(new Event('change'));
					}
				}
			}
		}


		function setupToggles() {
			const configs = [
				{ btnId: "toggleTypesBtn", containerId: "typesContainer" },
				{ btnId: "toggleMotifsBtn", containerId: "motifsContainer" },
				{ btnId: "toggleSiteBtn", containerId: "siteContainer" },
				{ btnId: "toggleSizesBtn", containerId: "sizesContainer" },
			];

			configs.forEach((config) => {
				const btn = document.getElementById(config.btnId);
				const container = document.getElementById(config.containerId);

				btn?.addEventListener("click", () => {
					const isCurrentlyOpen = container.style.display !== "none";

					// Close ALL first
					configs.forEach((c) => {
						const cContainer = document.getElementById(
							c.containerId,
						);
						const cBtn = document.getElementById(c.btnId);
						if (cContainer) cContainer.style.display = "none";
						if (cBtn) cBtn.classList.remove("active");
					});

					// If it was NOT open, open it
					if (!isCurrentlyOpen) {
						if (container) container.style.display = "block";
						if (btn) btn.classList.add("active");
					}
				});
			});
		}

		// Price Markup Logic (15% Discount Markup)
		const priceInputHidden = document.getElementById("product_price_input");
		const markupPreview = document.getElementById("price_markup_preview");
		const markupVal = document.getElementById("markup_val");
		const originalPriceInput = document.getElementById(
			"original_price_input",
		);

		if (priceInputHidden) {
			priceInputHidden.addEventListener("input", (e) => {
				const val = parseFloat(e.target.value);
				if (!isNaN(val) && val > 0) {
					// P = O * 0.85 => O = P / 0.85
					let originalPrice = Math.round(val / 0.85);
					originalPrice = Math.ceil(originalPrice / 10000) * 10000;
					const pct = (originalPrice - val).toLocaleString("id-ID");
					markupVal.innerText = originalPrice.toLocaleString("id-ID");
					originalPriceInput.value = originalPrice;
					const markupPctEl = document.getElementById("markup_pct");
					if(markupPctEl) markupPctEl.innerText = pct;
					markupPreview.style.display = "block";
				} else {
					markupPreview.style.display = "none";
					originalPriceInput.value = "";
				}
			});
		}

		// Naming Listeners Setup
		function setupNamingAutomation() {
			const itemCodeInput = document.getElementById("product_item_code_input");
			const categoryContainer = document.getElementById("sub-category-checkboxes");
			const l1Input = document.getElementById("l1_category_input");

			itemCodeInput?.addEventListener("input", updateName);
			categoryContainer?.addEventListener("change", updateName);

			const motifGrid = document.getElementById("motif-grid");
			motifGrid?.addEventListener("change", updateName);

			const colorGrid = document.getElementById("color-grid");
			colorGrid?.addEventListener("change", updateName);

			if (l1Input) {
				const observer = new MutationObserver(updateName);
				observer.observe(l1Input, { attributes: true });
			}

			// Trigger updateName when variant lining (dalaman) or variant selection changes
			document.addEventListener('change', (e) => {
				if (e.target && (e.target.classList.contains('v-dalaman-input-add') || e.target.classList.contains('variant-cb-add'))) {
					updateName();
				}
			});
		}


		setupToggles();
		initSearchableSelect();
		setupNamingAutomation();

		// Variasi UI Logic Tambah Produk
		document.querySelectorAll('.variant-cb-add').forEach(cb => {
			cb.addEventListener('change', (e) => {
				const parent = e.target.closest('.variant-item-add');
				const vSize = parent.querySelector('.v-size-input-add');
				const vSku = parent.querySelector('.v-sku-input-add');
				const vPriceDisp = parent.querySelector('.v-price-input-add');
				const vPriceHid = parent.querySelector('.v-price-hidden-add');
				const vStock = parent.querySelector('.v-stock-input-add');
				const vDalaman = parent.querySelector('.v-dalaman-input-add');
				const details = parent.querySelector('.v-details-add');
				
				const isChecked = e.target.checked;
				if(vSize) vSize.disabled = !isChecked;
				if(vSku) vSku.disabled = !isChecked;
				if(vPriceDisp) vPriceDisp.disabled = !isChecked;
				if(vPriceHid) vPriceHid.disabled = !isChecked;
				vStock.disabled = !isChecked;
				if(vDalaman) vDalaman.disabled = !isChecked;
				details.style.display = isChecked ? 'flex' : 'none';

				// Set default price based on main price input if empty
				if (isChecked && !vPriceDisp.value) {
					const mainPriceHid = document.getElementById("product_price_input");
					if(mainPriceHid && mainPriceHid.value) {
						vPriceHid.value = mainPriceHid.value;
						vPriceDisp.value = new Intl.NumberFormat('id-ID').format(mainPriceHid.value);
					}
				}
			});
		});

		// Currency Formatting Logic
		function initCurrencyMasks() {
			document.querySelectorAll('.currency-mask').forEach(input => {
				const formatPrice = (val) => {
					let str = val.toString();
					if (str.indexOf('.') !== -1 && str.indexOf('.') === str.lastIndexOf('.')) {
						const parts = str.split('.');
						if (parts[1].length === 2) {
							str = parts[0];
						}
					}
					const num = str.replace(/\D/g, '');
					return num ? new Intl.NumberFormat('id-ID').format(num) : '';
				};
				const getHidden = () => {
					if (input.dataset.hiddenId) return document.getElementById(input.dataset.hiddenId);
					return input.parentElement.querySelector('input[type="hidden"]');
				};

				const hidden = getHidden();
				input.addEventListener('input', (e) => {
					const rawVal = e.target.value.replace(/\D/g, '');
					e.target.value = formatPrice(e.target.value);
					if (hidden) {
						hidden.value = rawVal;
						hidden.dispatchEvent(new Event('input', { bubbles: true }));
					}
				});
				// Initial set on load
				if (input.value) { 
					input.value = formatPrice(input.value); 
					if(hidden) hidden.value = input.value.replace(/\D/g, '');
				}
			});
		}
		initCurrencyMasks();

		// Sleeve Mode Toggle Logic with Smart Autofill Migration
		const sleeveToggleAdd = document.getElementById('toggle_sleeve_options_add');
		if(sleeveToggleAdd) {
			sleeveToggleAdd.addEventListener('change', (e) => {
				const isChecked = e.target.checked;
				
				if (isChecked) {
					// 1. Collect standard checked data
					const standardData = {};
					document.querySelectorAll('.variant-item-add.variant-standard').forEach(el => {
						const cb = el.querySelector('.variant-cb-add');
						if (cb && cb.checked) {
							const sizeVal = cb.value; // e.g. "M" or "M SF"
							const priceDisp = el.querySelector('.v-price-input-add')?.value || '';
							const priceHid = el.querySelector('.v-price-hidden-add')?.value || '';
							const stock = el.querySelector('.v-stock-input-add')?.value || '0';
							const dalaman = el.querySelector('.v-dalaman-input-add')?.value || '';
							standardData[sizeVal] = { priceDisp, priceHid, stock, dalaman };
						}
					});

					// 2. Hide and reset standard items
					document.querySelectorAll('.variant-standard').forEach(el => {
						el.style.display = 'none';
						const cb = el.querySelector('.variant-cb-add');
						if (cb && cb.checked) {
							cb.checked = false;
							cb.dispatchEvent(new Event('change'));
						}
					});

					// 3. Show and pre-populate sleeve split items
					document.querySelectorAll('.variant-item-add.variant-sleeve-split').forEach(el => {
						el.style.display = 'flex';
						const cb = el.querySelector('.variant-cb-add');
						if (cb) {
							const cbVal = cb.value; // e.g. "M - Lengan Pendek"
							const baseSize = cbVal.split(' - ')[0].trim();
							if (standardData[baseSize]) {
								const data = standardData[baseSize];
								cb.checked = true;
								cb.dispatchEvent(new Event('change'));

								const vPriceDisp = el.querySelector('.v-price-input-add');
								const vPriceHid = el.querySelector('.v-price-hidden-add');
								const vStock = el.querySelector('.v-stock-input-add');
								const vDalaman = el.querySelector('.v-dalaman-input-add');

								if (vPriceDisp) vPriceDisp.value = data.priceDisp;
								if (vPriceHid) vPriceHid.value = data.priceHid;
								if (vStock) vStock.value = data.stock;
								if (vDalaman) vDalaman.value = data.dalaman;
							}
						}
					});
				} else {
					// 1. Collect sleeve split checked data
					const sleeveData = {};
					document.querySelectorAll('.variant-item-add.variant-sleeve-split').forEach(el => {
						const cb = el.querySelector('.variant-cb-add');
						if (cb && cb.checked) {
							const cbVal = cb.value; // e.g. "M - Lengan Pendek"
							const baseSize = cbVal.split(' - ')[0].trim();
							const priceDisp = el.querySelector('.v-price-input-add')?.value || '';
							const priceHid = el.querySelector('.v-price-hidden-add')?.value || '';
							const stock = el.querySelector('.v-stock-input-add')?.value || '0';
							const dalaman = el.querySelector('.v-dalaman-input-add')?.value || '';

							if (!sleeveData[baseSize]) {
								sleeveData[baseSize] = { priceDisp, priceHid, stock: parseInt(stock), dalaman };
							} else {
								sleeveData[baseSize].stock += parseInt(stock);
								if (parseFloat(priceHid) > parseFloat(sleeveData[baseSize].priceHid)) {
									sleeveData[baseSize].priceDisp = priceDisp;
									sleeveData[baseSize].priceHid = priceHid;
								}
							}
						}
					});

					// 2. Hide and reset sleeve split items
					document.querySelectorAll('.variant-sleeve-split').forEach(el => {
						el.style.display = 'none';
						const cb = el.querySelector('.variant-cb-add');
						if (cb && cb.checked) {
							cb.checked = false;
							cb.dispatchEvent(new Event('change'));
						}
					});

					// 3. Show and pre-populate standard items
					document.querySelectorAll('.variant-item-add.variant-standard').forEach(el => {
						el.style.display = 'flex';
						const cb = el.querySelector('.variant-cb-add');
						if (cb) {
							const sizeVal = cb.value; // e.g. "M"
							if (sleeveData[sizeVal]) {
								const data = sleeveData[sizeVal];
								cb.checked = true;
								cb.dispatchEvent(new Event('change'));

								const vPriceDisp = el.querySelector('.v-price-input-add');
								const vPriceHid = el.querySelector('.v-price-hidden-add');
								const vStock = el.querySelector('.v-stock-input-add');
								const vDalaman = el.querySelector('.v-dalaman-input-add');

								if (vPriceDisp) vPriceDisp.value = data.priceDisp;
								if (vPriceHid) vPriceHid.value = data.priceHid;
								if (vStock) vStock.value = data.stock.toString();
								if (vDalaman) vDalaman.value = data.dalaman;
							}
						}
					});
				}
			});
		}

