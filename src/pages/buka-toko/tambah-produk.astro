							lbl.querySelector('input').addEventListener('change', updateName);
							colorGrid.appendChild(lbl);
						}
						updateName();
					}

					if(item) {
							console.log("DEBUG: Item loaded successfully. Starting form auto-fill...");
							
							// Auto-detect color from name
							const colorList = ['HITAM', 'PUTIH', 'MERAH', 'KUNING', 'HIJAU', 'BIRU', 'COKLAT', 'ABU-ABU', 'KREM', 'UNGU', 'NAVY', 'MAROON', 'SOGA', 'TERACOTTA', 'PEACH', 'LAVENDER', 'MINT', 'OLIVE', 'DENIM', 'DUSTY', 'ROSE', 'GOLD', 'SILVER', 'TOSCA'];
							if (item.nama) {
