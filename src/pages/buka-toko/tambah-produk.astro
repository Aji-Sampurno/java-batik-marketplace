							// Auto-fill variants price and stock from item.details
							if (item.details) {
								try {
									const detailsArray = typeof item.details === 'string' ? JSON.parse(item.details) : item.details;
									if (Array.isArray(detailsArray)) {
										
										// 1. SISTEM DETEKSI TIPE SETELAN DI FRONTEND
										const isSetelan = (item.nama || '').toUpperCase().includes('STLAN') || (item.nama || '').toUpperCase().includes('SETELAN');
										
										if (isSetelan) {
											console.log("DEBUG: Mode Setelan Aktif. Membangun UI Pemecah & Penukar Atasan-Bawahan!");
											
											// Urutkan data agar berurutan sesuai fisik baris
											const sortedDetails = detailsArray.sort((a, b) => (a.id || 0) - (b.id || 0));
											const listCont = document.getElementById("custom-sizes-list-container");
											
											if (listCont) {
