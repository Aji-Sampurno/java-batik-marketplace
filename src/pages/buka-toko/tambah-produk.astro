								item = parsed;
								console.log("DEBUG: Found matching item in localStorage:", item);
							} else {
								console.log("DEBUG: ID mismatch in localStorage. URL ID: " + praProdukId + ", Local ID: " + (parsed ? parsed.id : ""));
							}
						} catch (e) {
							console.error("DEBUG: Failed to parse item from localStorage:", e);
						}
					}

					if (!item) {
						const qParam = urlParams.get('q');
						console.log("DEBUG: LocalStorage empty or mismatched. Fetching from API with qParam:", qParam);
						if (qParam) {
							const apiUrl = "https://noir.grace.gracianna.web.id/api/v1/beli1?per_page=12&q=" + encodeURIComponent(qParam);
							console.log("DEBUG: Fetching API URL:", apiUrl);
							const res = await fetch(apiUrl);
							const json = await res.json();
							console.log("DEBUG: API Response JSON:", json);
							if(json.success && json.data) {
								item = json.data.find(p => p.id == praProdukId);
								console.log("DEBUG: Found matched item in API data:", item);
							}
						} else {
							console.log("DEBUG: No q parameter found in URL query string.");
						}
					}

					function selectCategoryByName(catName) {
						const l1Select = document.querySelector('.searchable-select[data-ss-type="product-l1"]');
						if (!l1Select) return;
						const options = l1Select.querySelectorAll('.ss-option');
						let found = false;
						for (const opt of options) {
							const text = opt.querySelector('span')?.textContent?.trim()?.toLowerCase() || opt.textContent?.trim()?.toLowerCase();
							if (text === catName.toLowerCase() || text.includes(catName.toLowerCase())) {
								opt.click();
								found = true;
								break;
							}
						}
						
						// --- FALLBACK: If auto-detect mapping provides a category NOT in DB yet ---
						if (!found && catName) {
							console.log("DEBUG: Pre-product category not found in list. Auto-generating as Custom L1:", catName);
							const hiddenInput = document.getElementById("l1_category_input");
							const visibleInput = l1Select.querySelector(".ss-input");
							if(hiddenInput) hiddenInput.value = catName;
							if(visibleInput) visibleInput.value = catName;
							
							categoryModeL1 = "custom"; // Enable special dynamic engines
							renderSubCategoriesFromList(["_CUSTOM_L1_"]); // Render dynamically
							updateName(); // Sync naming
						}
					}

					function selectColorByName(colorName) {
						if (!colorName) return;
						const colorGrid = document.getElementById('color-grid');
						if (!colorGrid) return;
						
						const options = colorGrid.querySelectorAll('input[name="colors"]');
						let found = false;
						for (const opt of options) {
							if (opt.value.toLowerCase() === colorName.toLowerCase()) {
								opt.checked = true;
								found = true;
								break;
							}
						}
						
						if (!found) {
							// Add as new custom color
							const lbl = document.createElement('label');
							lbl.className = 'motif-style-label';
							lbl.style.gap = '0.5rem';
