								// Tambahkan fungsi tombol download
								const downloadBtn = document.getElementById("download_praproduk_btn");
								if (downloadBtn) {
									downloadBtn.onclick = function(e) {
										e.preventDefault();
										const currentSrc = imgPreview.src;
										if (!currentSrc) return;
										
										// Gunakan proxy API lokal kita untuk bypass CORS & force download
										const downloadUrl = `/api/proxy-image?url=${encodeURIComponent(currentSrc)}`;
