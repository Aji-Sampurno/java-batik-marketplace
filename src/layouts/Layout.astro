---
interface Props {
	title: string;
}

const { title } = Astro.props;
import { supabase } from '../lib/supabase';
import '../styles/index.css';

// Fetch Site Settings
let settings: any = { site_name: 'Batik Nusantara' };
if (supabase) {
  try {
    const { data } = await supabase.from('settings').select('*').single();
    if (data) settings = data;
  } catch (e) {
    console.error('Settings fetch error:', e);
  }
}

// Logic for Text Logo (Split by space)
const nameParts = settings.site_name.split(' ');
const firstWord = nameParts[0];
const restWords = nameParts.slice(1).join(' ');
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Marketplace Batik Eksklusif - Modern & Minimalist" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" href={`${settings.logo_url || "/favicon.png"}?v=1774431418`} />
		<link rel="shortcut icon" href={`${settings.logo_url || "/favicon.png"}?v=1774431418`} />
		<title>{title} | {settings.site_name}</title>
	</head>
	<body style="scroll-behavior: smooth;">
		<header id="main-header" style="position: absolute; top: 0; left: 0; right: 0; z-index: 100; transition: var(--transition); padding: 1.2rem 0;">
			<nav class="container" style="display: flex; justify-content: space-between; align-items: center;">
				<div class="logo">
					<a href="/" style="display: flex; align-items: center; gap: 0.8rem;">
						{settings.logo_url ? (
							<img src={settings.logo_url} alt={settings.site_name} style="height: 48px; width: auto;" />
						) : (
							<span id="logo-text" style="font-family: 'Playfair Display', serif; font-size: 1.6rem; letter-spacing: 1px; font-weight: 500; color: white;">
								{firstWord} <span style="font-style: italic; color: var(--color-accent-light);">{restWords}</span>
							</span>
						)}
					</a>
				</div>

				<!-- Desktop Navigation -->
				<ul style="display: flex; gap: var(--spacing-lg); list-style: none;" class="text-uppercase nav-links hide-mobile">
					<li><a href="/products" style="font-weight: 500; color: rgba(255,255,255,0.8);">Katalog</a></li>
					<li><a href="/about" style="font-weight: 500; color: rgba(255,255,255,0.8);">Tentang</a></li>
					<li><a href="/admin" style="opacity: 0.3; font-size: 0.6rem; color: white;">Admin</a></li>
				</ul>

				<!-- Mobile Menu Toggle -->
				<button id="mobile-menu-toggle" class="show-mobile" style="background: none; border: none; cursor: pointer; padding: var(--spacing-sm); z-index: 1001;">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path id="menu-icon-top" d="M4 6H20" stroke="white" stroke-width="2" stroke-linecap="round" style="transition: var(--transition);"/>
						<path id="menu-icon-mid" d="M4 12H20" stroke="white" stroke-width="2" stroke-linecap="round" style="transition: var(--transition);"/>
						<path id="menu-icon-bot" d="M4 18H20" stroke="white" stroke-width="2" stroke-linecap="round" style="transition: var(--transition);"/>
					</svg>
				</button>
			</nav>

			<!-- Mobile Menu Overlay -->
			<div id="mobile-menu" class="show-mobile" style="position: fixed; top: 0; left: 0; width: 100%; height: 100dvh; background: var(--color-bg); z-index: 1000; transform: translateY(-100%); transition: transform 0.6s cubic-bezier(0.85, 0, 0.15, 1); display: flex; flex-direction: column; justify-content: center; align-items: center; gap: var(--spacing-xl); padding: var(--spacing-2xl);">
				<ul style="list-style: none; text-align: center; display: flex; flex-direction: column; gap: var(--spacing-lg);" class="text-uppercase">
					<li><a href="/" style="font-size: 1.5rem; font-weight: 500; color: var(--color-text);">Beranda</a></li>
					<li><a href="/products" style="font-size: 1.5rem; font-weight: 500; color: var(--color-text);">Katalog</a></li>
					<li><a href="/about" style="font-size: 1.5rem; font-weight: 500; color: var(--color-text);">Tentang Kami</a></li>
					<li><a href="/admin" style="opacity: 0.5; font-size: 0.8rem; color: var(--color-text);">Admin Panel</a></li>
				</ul>
				
				<div style="margin-top: var(--spacing-xl); text-align: center; opacity: 0.6;">
					<p style="font-size: 0.8rem; margin-bottom: var(--spacing-sm);">{settings.site_name}</p>
					<div style="display: flex; gap: var(--spacing-md); justify-content: center;">
						{settings.url_instagram && <a href={settings.url_instagram} style="font-size: 0.7rem;">IG</a>}
						{settings.url_whatsapp && <a href={`https://wa.me/${settings.url_whatsapp}`} style="font-size: 0.7rem;">WA</a>}
					</div>
				</div>
			</div>
		</header>
		<main>
			<slot />
		</main>
		<footer style="background: #0a0a0a; color: white; padding: var(--spacing-2xl) 0 var(--spacing-xl) 0; border-top: 1px solid rgba(255,255,255,0.05);">
			<div class="container">
				<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--spacing-xl); margin-bottom: var(--spacing-xl);">
					<!-- Brand -->
					<div>
						<a href="/" style="display: inline-block; margin-bottom: var(--spacing-md);">
							{settings.logo_url ? (
								<img src={settings.logo_url} alt={settings.site_name} style="height: 40px;" />
							) : (
								<span style="font-family: 'Playfair Display', serif; font-size: 1.4rem; letter-spacing: 1px; color: white;">
									{firstWord} <span style="font-style: italic; color: var(--color-accent-light);">{restWords}</span>
								</span>
							)}
						</a>
						<p style="font-size: 0.8rem; opacity: 0.4; line-height: 1.6; max-width: 250px;">
							Menghubungkan warisan budaya Indonesia dengan gaya hidup modern yang minimalis.
						</p>
					</div>

					<!-- Location -->
					<div>
						<h4 class="text-uppercase" style="font-size: 0.75rem; margin-bottom: var(--spacing-lg); letter-spacing: 1px; color: var(--color-accent-light);">Butik Offline</h4>
						<p style="font-size: 0.85rem; opacity: 0.7; line-height: 1.8;">
							{settings.address || 'Alamat belum diatur di dashboard admin.'}
						</p>
					</div>

					<!-- Contact -->
					<div>
						<h4 class="text-uppercase" style="font-size: 0.75rem; margin-bottom: var(--spacing-lg); letter-spacing: 1px; color: var(--color-accent-light);">Layanan Admin</h4>
						<ul style="list-style: none; padding: 0;">
							{settings.contact_whatsapp && (
								<li style="margin-bottom: 0.5rem;">
									<a href={`https://wa.me/${settings.contact_whatsapp}`} target="_blank" style="font-size: 0.85rem; color: white; opacity: 0.7; text-decoration: none; border-bottom: 1px solid transparent; transition: 0.3s;" onmouseover="this.style.opacity=1; this.style.borderBottomColor='white'" onmouseout="this.style.opacity=0.7; this.style.borderBottomColor='transparent'">WhatsApp: +{settings.contact_whatsapp}</a>
								</li>
							)}
							<li><a href="/about" style="font-size: 0.85rem; color: white; opacity: 0.7;">Tentang Kami</a></li>
							<li><a href="/products" style="font-size: 0.85rem; color: white; opacity: 0.7;">Koleksi Terbaru</a></li>
						</ul>
					</div>

					<!-- Channels -->
					<div>
						<h4 class="text-uppercase" style="font-size: 0.75rem; margin-bottom: var(--spacing-lg); letter-spacing: 1px; color: var(--color-accent-light);">Kunjungi Kami</h4>
						<div style="display: flex; flex-direction: column; gap: 0.5rem;">
							{settings.url_tokopedia && <a href={settings.url_tokopedia} target="_blank" style="font-size: 0.85rem; color: white; opacity: 0.7;">Tokopedia</a>}
							{settings.url_shopee && <a href={settings.url_shopee} target="_blank" style="font-size: 0.85rem; color: white; opacity: 0.7;">Shopee</a>}
							{settings.url_instagram && <a href={settings.url_instagram} target="_blank" style="font-size: 0.85rem; color: white; opacity: 0.7;">Instagram</a>}
							{settings.url_tiktok && <a href={settings.url_tiktok} target="_blank" style="font-size: 0.85rem; color: white; opacity: 0.7;">TikTok</a>}
						</div>
					</div>
				</div>

				<div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: var(--spacing-xl); text-align: center;">
					<p class="text-uppercase opacity-30" style="font-size: 0.65rem; letter-spacing: 2px;">
						&copy; 2026 {settings.site_name}. All Rights Reserved.
					</p>
				</div>
			</div>
		</footer>

		<script is:inline>
			// Centralized Scroll & Animation Logic
			const header = document.getElementById('main-header');
			const mobileMenu = document.getElementById('mobile-menu');
			const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
			const menuIconTop = document.getElementById('menu-icon-top');
			const menuIconMid = document.getElementById('menu-icon-mid');
			const menuIconBot = document.getElementById('menu-icon-bot');
			const logoText = document.getElementById('logo-text');
			
			let isMenuOpen = false;

			const toggleMenu = () => {
				isMenuOpen = !isMenuOpen;
				mobileMenu.style.transform = isMenuOpen ? 'translateY(0)' : 'translateY(-100%)';
				document.body.classList.toggle('mobile-menu-open', isMenuOpen);
				
				// Animate Hamburger to X
				if (isMenuOpen) {
					menuIconTop.setAttribute('d', 'M6 18L18 6');
					menuIconMid.setAttribute('d', 'M6 6L18 18');
					menuIconBot.setAttribute('d', 'M6 6L18 18');
					menuIconTop.setAttribute('stroke', 'var(--color-text)');
					menuIconMid.setAttribute('stroke', 'var(--color-text)');
					menuIconBot.setAttribute('stroke', 'var(--color-text)');
				} else {
					menuIconTop.setAttribute('d', 'M4 6H20');
					menuIconMid.setAttribute('d', 'M4 12H20');
					menuIconBot.setAttribute('d', 'M4 18H20');
					updateHeaderColors();
				}
			};

			const updateHeaderColors = () => {
				const isGlass = window.scrollY > 50;
				const color = isGlass ? 'var(--color-text)' : 'white';
				
				if (!isMenuOpen) {
					menuIconTop.setAttribute('stroke', color);
					menuIconMid.setAttribute('stroke', color);
					menuIconBot.setAttribute('stroke', color);
				}
				if (logoText) logoText.style.color = color;
			};

			const handleHeader = () => {
				if (window.scrollY > 50) {
					header.classList.add('glass-header');
					header.style.position = 'fixed';
				} else {
					header.classList.remove('glass-header');
					header.style.position = 'absolute';
				}
				updateHeaderColors();
			};

			mobileMenuToggle.addEventListener('click', toggleMenu);

			const observerOptions = {
				threshold: 0.1,
				rootMargin: '0px 0px -50px 0px'
			};

			const revealObserver = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						const delay = entry.target.getAttribute('data-delay') || 0;
						setTimeout(() => {
							entry.target.classList.add('active');
						}, delay);
						revealObserver.unobserve(entry.target);
					}
				});
			}, observerOptions);

			// Init
			window.addEventListener('scroll', handleHeader);
			document.querySelectorAll('.reveal, .reveal-up, .reveal-left, .reveal-right, .reveal-scale').forEach(el => revealObserver.observe(el));
			handleHeader(); // Initial check
		</script>
	</body>
</html>
