---
// Extract current Props
interface Props {
	product: any;
	index: number;
	settings: any;
}

const { product: p, index, settings } = Astro.props;

const getProductDisplaySizes = (prod: any) => {
	const variants = prod.variants || prod.product_variants || [];
	if (variants.length > 0) {
		const mappedSizes = variants.map((v: any) => {
			let sizeName = v.size_name || "";
			let baseSize = sizeName.trim();
			if (sizeName.includes(" - ")) {
				baseSize = sizeName.split(" - ")[0].trim();
			}
			const sfRegex = /\bSF\b|\bSlim\s*Fit\b|\bSlim\b/i;
			if (sfRegex.test(baseSize)) {
				baseSize = baseSize
					.replace(sfRegex, "")
					.replace(/[-_\s/]+$/, "")
					.trim();
			}
			return baseSize.toUpperCase();
		});
		const uniqueSizes = [...new Set(mappedSizes)].filter(
			(sz: any) => (isNaN(Number(sz)) || sz.length <= 3) && sz,
		);
		const sizeOrder = ["S", "M", "L", "XL", "XXL", "3XL", "ALL SIZE"];
		uniqueSizes.sort((a, b) => {
			const idxA = sizeOrder.indexOf(a);
			const idxB = sizeOrder.indexOf(b);
			if (idxA !== -1 && idxB !== -1) return idxA - idxB;
			if (idxA !== -1) return -1;
			if (idxB !== -1) return 1;
			return a.localeCompare(b);
		});
		return uniqueSizes;
	} else if (prod.sizes && prod.sizes.length > 0) {
		const mappedSizes = prod.sizes.map((s: any) => {
			const sfRegex = /\bSF\b|\bSlim\s*Fit\b|\bSlim\b/i;
			return s
				.replace(sfRegex, "")
				.replace(/[-_\s/]+$/, "")
				.trim()
				.toUpperCase();
		});
		const uniqueSizes = [...new Set(mappedSizes)].filter(
			(s: any) => (isNaN(Number(s)) || s.length <= 3) && s,
		);
		return uniqueSizes;
	}
	return [];
};

const isOutOfStock =
	!p.is_active ||
	(p.total_inventory !== undefined ? Number(p.total_inventory) === 0 : (p.total_stock === 0 || p.stock_status === "habis"));

const waBaseUrl = "https://wa.me/";
---

<div
	class={`product-card reveal-up ${isOutOfStock ? "product-inactive" : ""}`}
	data-delay={(index % 4) * 100}
>
	<div
		class="product-image"
		style="position: relative;"
	>
		<a href={`/products/${p.id}`}>
			<img
				src={
					p.image_url ||
					"https://via.placeholder.com/400x600?text=Batik"
				}
				alt={p.name}
				loading="lazy"
				class={
					isOutOfStock
						? "out-of-stock-img"
						: ""
				}
			/>
			{isOutOfStock && (
				<div class="ribbon-wrapper">
					<div class="ribbon">
						HABIS
					</div>
				</div>
			)}
		</a>
	</div>

	<div
		class="product-info"
		style="display: flex; flex-direction: column; flex: 1;"
	>
		<div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.2rem; flex-wrap: wrap; gap: 0.5rem;">
			<p
				class="text-uppercase color-accent"
				style="font-size: 0.65rem; color: var(--color-accent); margin: 0;"
			>
				{p.types?.name ||
					p.type?.name ||
					"-"}{" "}
				•{" "}
				{(
					p.motifs ||
					p.product_motifs ||
					[]
				)
					?.map(
						(pm: any) =>
							pm.name ||
							pm.motifs?.name,
					)
					.filter(Boolean)
					.join(", ") || "-"}
			</p>
			{p.code && (
				<span style="font-size: 0.65rem; color: #a3a3a3; font-family: monospace; font-weight: 500; letter-spacing: 0.5px;">
					#{p.code}
				</span>
			)}
		</div>
		<h3 class="product-title">
			<a
				href={`/products/${p.id}`}
				style="color: inherit; text-decoration: none;"
			>
				{p.name}
			</a>
		</h3>

		<div class="product-meta">
			{getProductDisplaySizes(p).map(
				(sz: any) => (
					<span style="font-size: 0.65rem; border: 1px solid #e2e8f0; padding: 2px 8px; border-radius: 4px; color: #475569; background: #f8fafc; font-weight: 500; text-transform: uppercase;">
						{sz}
					</span>
				),
			)}
		</div>

		<div style="display: flex; align-items: center; gap: 0.5rem;">
			{p.original_price &&
				Number(p.original_price) >
					Number(p.price) && (
					<span style="text-decoration: line-through; color: #999; font-size: 0.8rem;">
						Rp{" "}
						{Number(
							p.original_price,
						).toLocaleString(
							"id-ID",
						)}
					</span>
				)}
			<p
				class="price-tag"
				style="margin: 0;"
			>
				{(() => {
					let displayPrice = `Rp ${Number(p.price).toLocaleString("id-ID")}`;
					const variants = p.variants || p.product_variants || [];
					if (
						variants.length > 0
					) {
						const vPrices =
							variants.map(
								(v: any) =>
									v.price,
							);
						const vMin =
							Math.min(
								...vPrices,
							);
						if (vMin > 0) {
							displayPrice = `Rp ${vMin.toLocaleString("id-ID")}`;
						}
					}
					return displayPrice;
				})()}
			</p>
		</div>

		<div class="actions">
			{p.tokopedia_url && (
				<a
					href={
						!isOutOfStock
							? p.tokopedia_url
							: "javascript:void(0)"
					}
					target={
						!isOutOfStock
							? "_blank"
							: "_self"
					}
					class={`buy-btn ${isOutOfStock ? "disabled-btn" : ""}`}
				>
					{!isOutOfStock
						? "Beli Sekarang"
						: "HABIS TERJUAL"}
				</a>
			)}
			<a
				href={
					!isOutOfStock
						? `${waBaseUrl}${settings.contact_whatsapp}?text=Halo, saya tertarik dengan produk ${p.name}`
						: "javascript:void(0)"
				}
				target={
					!isOutOfStock
						? "_blank"
						: "_self"
				}
				class={`wa-btn ${isOutOfStock ? "disabled-btn" : ""}`}
			>
				{!isOutOfStock
					? "Chat Admin"
					: "CEK PRODUK LAIN"}
			</a>
		</div>
	</div>
</div>

<style>
	.product-card {
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.product-image {
		aspect-ratio: 4/5;
		overflow: hidden;
	}

	.product-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: filter 0.3s ease;
	}

	.product-inactive {
		opacity: 0.85;
	}

	.out-of-stock-img {
		filter: grayscale(1) contrast(0.8);
	}

	/* Diagonal Ribbon */
	.ribbon-wrapper {
		width: 120px;
		height: 120px;
		overflow: hidden;
		position: absolute;
		top: -4px;
		right: -4px;
		z-index: 10;
		pointer-events: none;
	}

	.ribbon {
		font-family: var(--font-main);
		font-weight: 800;
		color: #fff;
		text-align: center;
		transform: rotate(45deg);
		position: absolute;
		padding: 7px 0;
		top: 25px;
		right: -40px;
		width: 180px;
		background-color: #b91c1c;
		box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
		font-size: 0.75rem;
		letter-spacing: 3px;
		text-transform: uppercase;
	}

	.product-title {
		font-family: var(--font-main);
		font-size: 1.1rem;
		font-weight: 500;
		margin-bottom: 0.5rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		min-height: 2.8rem; /* Forces consistent height for 2 lines */
	}

	.product-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 1rem;
	}

	.actions {
		margin-top: auto;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding-top: 1.5rem;
	}

	.buy-btn {
		background: #1a1a1a;
		color: white;
		text-align: center;
		padding: 0.8rem;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 2px;
		font-weight: 600;
		transition: all 0.3s;
		text-decoration: none;
	}

	.wa-btn {
		border: 1px solid var(--color-text);
		color: var(--color-text);
		text-align: center;
		padding: 0.8rem;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 2px;
		transition: all 0.3s;
		text-decoration: none;
	}

	.disabled-btn {
		background: #f5f5f5 !important;
		color: #aaa !important;
		border-color: #eee !important;
		cursor: not-allowed !important;
		pointer-events: none !important;
		transform: none !important;
		box-shadow: none !important;
	}
	
	.product-card:hover h3 {
		color: var(--color-accent);
	}
	
	.price-tag {
		font-weight: 600;
		color: var(--color-accent);
		font-size: 1.1rem;
	}
</style>
