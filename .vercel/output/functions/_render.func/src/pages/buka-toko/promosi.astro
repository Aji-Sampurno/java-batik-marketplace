---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { apiFetch, uploadToLaravel } from "../../lib/api";

// Check for session (Authentication Gate)
const session = Astro.cookies.get("admin_session");
if (session?.value !== "authenticated") {
	return Astro.redirect("/login");
}

let promotions: any[] = [];
let settings: any = null;

try {
	const pr = await apiFetch<any>("promotions");
	promotions = pr?.data || pr || [];

	const s = await apiFetch<any>("settings");
	settings = s?.data || s || { site_name: "Batik Nusantara" };
} catch (e) {
	console.error("Promotions/Settings fetch error:", e);
}

// Handle Form Submission
if (Astro.request.method === "POST") {
	try {
		const formData = await Astro.request.formData();
		const action = formData.get("action");

		if (action === "add_promo") {
			const title = formData.get("title");
			const link_url = formData.get("link_url") || "/products";
			const order_index = formData.get("order_index") || 0;
			const promo_file = formData.get("promo_file") as File;
			let image_url = "";

			if (promo_file && promo_file.size > 0) {
				image_url = await uploadToLaravel(promo_file, "promotions");
			}

			await apiFetch("promotions", {
				method: "POST",
				body: JSON.stringify({ title, image_url, link_url, order_index, is_active: true }),
			});
			return Astro.redirect("/buka-toko/promosi?success=promo");
		}

		if (action === "delete_promo") {
			const id = formData.get("id");
			await apiFetch(`promotions/${id}`, { method: "DELETE" });
			return Astro.redirect("/buka-toko/promosi?success=deleted");
		}

		if (action === "toggle_promo") {
			const id = formData.get("id");
			const current_status = formData.get("current_status") === "true";
			await apiFetch(`promotions/${id}`, {
				method: "PUT",
				body: JSON.stringify({ is_active: !current_status }),
			});
			return Astro.redirect("/buka-toko/promosi?success=status");
		}
	} catch (e: any) {
		console.error("Action error:", e);
		return Astro.redirect(`/buka-toko/promosi?error=${encodeURIComponent(e.message || "Terjadi kesalahan sistem")}`);
	}
}

const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
let message = "";
if (success === "promo") message = "Promo berhasil ditambahkan!";
if (success === "deleted") message = "Promo berhasil dihapus!";
if (success === "status") message = "Status promo diperbarui!";

---

<Layout title={`Kelola Promo - ${settings?.site_name}`}>
	<section style="padding: 100px 0; background: #fdfcfb; min-height: 100vh;">
		<div class="container">
			<!-- Header -->
			<div
				style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem;"
			>
				<div>
					<a
						href="/buka-toko"
						style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; color: var(--color-accent); text-decoration: none; display: flex; align-items: center; gap: 8px; margin-bottom: 1rem; position: relative; z-index: 1001; cursor: pointer;"
					>
						<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
						Kembali ke Dashboard
					</a>
					<h1
						style="font-family: var(--font-serif); font-size: 2.5rem; margin: 0; font-weight: 400;"
					>
						Manajemen <span style="font-style: italic;">Promosi</span>
					</h1>
					<p style="opacity: 0.5; margin-top: 0.5rem;">
						Kelola banner dan penawaran spesial di halaman depan.
					</p>
				</div>
			</div>

			<!-- Flash Message -->
			{
				message && (
					<div
						style="background: #e6f9e9; color: #0d5a15; padding: 1rem 1.5rem; border-radius: 8px; margin-bottom: 2rem; display: flex; align-items: center; gap: 10px; font-size: 0.9rem; border: 1px solid rgba(13, 90, 21, 0.1);"
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
						{message}
					</div>
				)
			}

			<!-- Error Message -->
			{
				error && (
					<div
						style="background: #fff5f5; color: #b91c1c; padding: 1rem 1.5rem; border-radius: 8px; margin-bottom: 2rem; display: flex; align-items: center; gap: 10px; font-size: 0.9rem; border: 1px solid rgba(185, 28, 28, 0.1);"
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 8v4M12 16h.01"/></svg>
						<strong>Error:</strong> {error}
					</div>
				)
			}


			<div
				style="display: grid; grid-template-columns: 350px 1fr; gap: 3rem; align-items: start;"
			>
				<!-- Form Section -->
				<div class="glass-form" style="position: sticky; top: 120px;">
					<h2
						class="text-uppercase"
						style="font-size: 0.75rem; letter-spacing: 2px; margin-bottom: 1.5rem; opacity: 0.8; font-weight: 700;"
					>
						Tambah Banner Baru
					</h2>

					<form
						method="POST"
						enctype="multipart/form-data"
						style="display: flex; flex-direction: column; gap: 1.2rem;"
					>
						<input type="hidden" name="action" value="add_promo" />

						<div>
							<label class="input-label">Judul Banner</label>
							<input
								name="title"
								type="text"
								required
								placeholder="Promo Koleksi Sutra"
								class="admin-input"
							/>
						</div>

						<div>
							<label class="input-label">Link Tujuan</label>
							<input
								name="link_url"
								type="text"
								placeholder="/products?type=Kain"
								class="admin-input"
							/>
						</div>

						<div
							style="display: grid; grid-template-columns: 80px 1fr; gap: 15px;"
						>
							<div>
								<label class="input-label">Urutan</label>
								<input
									name="order_index"
									type="number"
									value="0"
									class="admin-input"
								/>
							</div>
							<div>
								<label class="input-label">File Gambar</label>
								<input
									name="promo_file"
									type="file"
									accept="image/*"
									required
									style="font-size: 0.7rem; margin-top: 5px;"
								/>
								<p style="font-size: 0.65rem; opacity: 0.4; margin-top: 4px; color: var(--color-accent); font-weight: 600;">
									Rekomendasi rasio 2:1 (Contoh: 1500 x 750 px)
								</p>

							</div>
						</div>

						<button type="submit" class="btn-save">
							Simpan Promo
						</button>
					</form>
				</div>

				<!-- List Section -->
				<div>
					<div
						style="background: white; border-radius: var(--radius-md); overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.03); border: 1px solid #f1f1f1;"
					>
						<table style="width: 100%; border-collapse: collapse;">
							<thead>
								<tr style="background: #fafafa; border-bottom: 1px solid #f0f0f0;">
									<th class="th-style">Preview</th>
									<th class="th-style">Informasi Promo</th>
									<th class="th-style" style="text-align: center;">Status</th>
									<th class="th-style" style="text-align: right;">Aksi</th>
								</tr>
							</thead>
							<tbody>
								{
									promotions.map((p) => (
										<tr style="border-bottom: 1px solid #f9f9f9;">
											<td style="padding: 1.5rem;">
												<div class="promo-preview-box">
													<img src={p.image_url} alt={p.title} />
												</div>
											</td>
											<td style="padding: 1.5rem;">
												<div style="font-weight: 600; font-size: 1rem; color: #111;">
													{p.title}
												</div>
												<div style="font-size: 0.75rem; opacity: 0.4; margin-top: 4px;">
													Link: {p.link_url}
												</div>
												<div style="font-size: 0.7rem; font-weight: 700; color: var(--color-accent); margin-top: 8px; text-transform: uppercase; letter-spacing: 1px;">
													Urutan #{p.order_index}
												</div>
											</td>
											<td style="padding: 1.5rem; text-align: center;">
												<form method="POST">
													<input type="hidden" name="action" value="toggle_promo" />
													<input type="hidden" name="id" value={p.id} />
													<input type="hidden" name="current_status" value={String(p.is_active)} />
													<button 
														type="submit" 
														class={`status-toggle ${p.is_active ? 'active' : 'inactive'}`}
													>
														{p.is_active ? 'Aktif' : 'Nonaktif'}
													</button>
												</form>
											</td>
											<td style="padding: 1.5rem; text-align: right;">
												<form method="POST" class="delete-form">
													<input type="hidden" name="action" value="delete_promo" />
													<input type="hidden" name="id" value={p.id} />
													<button 
														type="button" 
														class="btn-delete"
														onclick="openDeleteModal(this.form)"
													>
														<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
													</button>
												</form>
											</td>
										</tr>
									))
								}
							</tbody>
						</table>
						{
							promotions.length === 0 && (
								<div style="padding: 4rem; text-align: center; opacity: 0.3;">
									<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="margin-bottom: 1rem;"><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/><path d="M12 8v4M12 16h.01"/></svg>
									<p>Belum ada banner promo yang ditambahkan.</p>
								</div>
							)
						}
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Custom Delete Modal -->
	<div id="delete-modal" class="modal-overlay">
		<div class="modal-content">
			<div class="modal-header">
				<div class="warning-icon">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01"/></svg>
				</div>
				<h3 style="font-family: var(--font-serif); font-size: 1.5rem; font-weight: 400; margin: 0;">Konfirmasi <span style="font-style: italic;">Hapus</span></h3>
			</div>
			<p style="opacity: 0.6; line-height: 1.6; margin: 1.5rem 0; font-size: 0.95rem;">Apakah Anda yakin ingin menghapus promo ini secara permanen? Tindakan ini tidak dapat dibatalkan.</p>
			<div class="modal-footer">
				<button type="button" id="cancel-btn" class="btn-admin-secondary">Batal</button>
				<button type="button" id="confirm-btn" class="btn-admin-danger">Ya, Hapus</button>
			</div>
		</div>
	</div>

	<script is:inline>
		let currentForm = null;
		const modal = document.getElementById('delete-modal');
		const confirmBtn = document.getElementById('confirm-btn');
		const cancelBtn = document.getElementById('cancel-btn');

		window.openDeleteModal = function(form) {
			currentForm = form;
			modal.classList.add('active');
			document.body.style.overflow = 'hidden';
		}

		function closeModal() {
			modal.classList.remove('active');
			document.body.style.overflow = '';
			currentForm = null;
		}

		cancelBtn.addEventListener('click', closeModal);
		
		confirmBtn.addEventListener('click', () => {
			if (currentForm) {
				confirmBtn.disabled = true;
				confirmBtn.innerText = "Menghapus...";
				currentForm.submit();
			}
		});

		// Close on click outside
		modal.addEventListener('click', (e) => {
			if (e.target === modal) closeModal();
		});
	</script>


	<style>
		.glass-form {
			background: white;
			padding: 2rem;
			border-radius: 12px;
			border: 1px solid #f0f0f0;
			box-shadow: 0 4px 20px rgba(0,0,0,0.02);
		}

		.input-label {
			font-size: 0.65rem;
			text-transform: uppercase;
			letter-spacing: 1.5px;
			opacity: 0.5;
			font-weight: 700;
			display: block;
			margin-bottom: 0.5rem;
		}

		.admin-input {
			width: 100%;
			padding: 0.8rem 1rem;
			border: 1px solid #e5e7eb;
			border-radius: 8px;
			font-size: 0.9rem;
			transition: all 0.3s;
			background: #fdfdfd;
		}

		.admin-input:focus {
			border-color: var(--color-accent);
			outline: none;
			background: white;
			box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.05);
		}

		.btn-save {
			background: #111;
			color: white;
			border: none;
			padding: 1rem;
			border-radius: 8px;
			font-size: 0.8rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 2px;
			cursor: pointer;
			transition: all 0.3s;
			margin-top: 1rem;
		}

		.btn-save:hover {
			background: #000;
			transform: translateY(-2px);
			box-shadow: 0 10px 20px rgba(0,0,0,0.1);
		}

		.th-style {
			padding: 1.2rem 1.5rem;
			text-align: left;
			font-size: 0.65rem;
			text-transform: uppercase;
			letter-spacing: 2px;
			color: #999;
			font-weight: 700;
		}

		.promo-preview-box {
			width: 160px;
			aspect-ratio: 2 / 1;
			border-radius: 8px;
			overflow: hidden;
			background: #f5f5f5;
			border: 1px solid #eee;
		}


		.promo-preview-box img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

		.status-toggle {
			padding: 6px 12px;
			border-radius: 100px;
			font-size: 0.65rem;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 1px;
			cursor: pointer;
			border: 1px solid transparent;
			transition: all 0.3s;
		}

		.status-toggle.active {
			background: #e6f9e9;
			color: #0d5a15;
			border-color: rgba(13, 90, 21, 0.1);
		}

		.status-toggle.inactive {
			background: #f9f9f9;
			color: #999;
			border-color: #eee;
		}

		.btn-delete {
			background: none;
			border: none;
			color: #ff4d4d;
			cursor: pointer;
			padding: 8px;
			border-radius: 8px;
			transition: all 0.3s;
			opacity: 0.4;
		}

		.btn-delete:hover {
			background: #fff5f5;
			color: #b91c1c;
			border-color: rgba(185, 28, 28, 0.2);
			transform: scale(1.1);
		}

		/* Modal Styles */
		.modal-overlay {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: rgba(0, 0, 0, 0.4);
			backdrop-filter: blur(4px);
			display: flex;
			align-items: center;
			justify-content: center;
			z-index: 9999;
			opacity: 0;
			visibility: hidden;
			transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		}

		.modal-overlay.active {
			opacity: 1;
			visibility: visible;
		}

		.modal-content {
			background: white;
			width: 100%;
			max-width: 400px;
			padding: 2.5rem;
			border-radius: 16px;
			box-shadow: 0 20px 50px rgba(0,0,0,0.15);
			transform: translateY(20px);
			transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		}

		.modal-overlay.active .modal-content {
			transform: translateY(0);
		}

		.modal-header {
			display: flex;
			align-items: center;
			gap: 15px;
			margin-bottom: 1rem;
		}

		.warning-icon {
			width: 40px;
			height: 40px;
			background: #fff5f5;
			color: #b91c1c;
			border-radius: 12px;
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.modal-footer {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 12px;
			margin-top: 0.5rem;
		}

		.btn-admin-secondary {
			padding: 0.8rem;
			border-radius: 8px;
			font-size: 0.75rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 1px;
			cursor: pointer;
			background: #f5f5f5;
			border: 1px solid #eee;
			color: #666;
			transition: all 0.2s;
		}

		.btn-admin-secondary:hover {
			background: #eee;
		}

		.btn-admin-danger {
			padding: 0.8rem;
			border-radius: 8px;
			font-size: 0.75rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 1px;
			cursor: pointer;
			background: #b91c1c;
			border: none;
			color: white;
			transition: all 0.2s;
		}

		.btn-admin-danger:hover {
			background: #991b1b;
			box-shadow: 0 4px 12px rgba(185, 28, 28, 0.2);
		}
	</style>
</Layout>
